<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEON STRIKE</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;500;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{overflow:hidden;background:#0a0a12;font-family:'Rajdhani',sans-serif;cursor:default}
canvas{display:block}
#startScreen{position:fixed;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:radial-gradient(ellipse at 50% 40%,#1a0808 0%,#0a0a12 70%);z-index:100}
#startScreen h1{font-family:'Orbitron',monospace;font-size:clamp(2.5rem,8vw,5.5rem);font-weight:900;color:#ff2d2d;text-shadow:0 0 40px rgba(255,45,45,.5),0 0 80px rgba(255,45,45,.15);letter-spacing:.12em;margin-bottom:.3rem}
.subtitle{font-size:clamp(.8rem,2vw,1.1rem);color:#00e5ff;letter-spacing:.35em;text-transform:uppercase;margin-bottom:3rem;opacity:.7}
.start-btn{font-family:'Orbitron',monospace;font-size:1.1rem;font-weight:700;padding:1rem 3.5rem;background:transparent;color:#ff2d2d;border:2px solid #ff2d2d;cursor:pointer;letter-spacing:.18em;transition:all .3s;text-transform:uppercase}
.start-btn:hover{background:#ff2d2d;color:#0a0a12;box-shadow:0 0 40px rgba(255,45,45,.4)}
.controls-info{margin-top:2.5rem;color:#444;font-size:.85rem;text-align:center;line-height:2}
.controls-info span{color:#777;font-weight:700}
#hud{position:fixed;inset:0;pointer-events:none;z-index:10;display:none}
#crosshair{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:22px;height:22px}
#crosshair::before,#crosshair::after{content:'';position:absolute;background:rgba(255,255,255,.7)}
#crosshair::before{top:0;left:50%;width:1.5px;height:100%;transform:translateX(-50%)}
#crosshair::after{left:0;top:50%;height:1.5px;width:100%;transform:translateY(-50%)}
.ch-dot{position:absolute;top:50%;left:50%;width:3px;height:3px;background:#ff2d2d;border-radius:50%;transform:translate(-50%,-50%)}
#hitMarker{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:22px;height:22px;opacity:0;transition:opacity .08s;pointer-events:none}
#hitMarker::before,#hitMarker::after{content:'';position:absolute;top:50%;left:50%;width:14px;height:2px;background:#ff2d2d;transform-origin:center}
#hitMarker::before{transform:translate(-50%,-50%) rotate(45deg)}
#hitMarker::after{transform:translate(-50%,-50%) rotate(-45deg)}
#hitMarker.show{opacity:1}
#healthBar{position:absolute;bottom:36px;left:36px;display:flex;align-items:center;gap:10px}
.bar-bg{width:180px;height:6px;background:rgba(255,255,255,.08);border-radius:3px;overflow:hidden}
.bar-fill{height:100%;background:linear-gradient(90deg,#ff2d2d,#ff6b4a);border-radius:3px;transition:width .25s;width:100%}
.hp-val{font-family:'Orbitron',monospace;font-size:1.5rem;font-weight:700;color:#ff2d2d;min-width:50px}
#ammoDisplay{position:absolute;bottom:36px;right:36px;text-align:right}
.ammo-cur{font-family:'Orbitron',monospace;font-size:2.6rem;font-weight:900;color:#fff;line-height:1}
.ammo-res{font-family:'Rajdhani',sans-serif;font-size:1.1rem;color:#555}
.weapon-label{font-size:.7rem;color:#00e5ff;letter-spacing:.22em;text-transform:uppercase;margin-bottom:2px}
#scoreDisplay{position:absolute;top:26px;right:36px;text-align:right}
.score-val{font-family:'Orbitron',monospace;font-size:1.8rem;font-weight:700;color:#fff}
.wave-val{font-size:.8rem;color:#00e5ff;letter-spacing:.18em}
#minimap{position:absolute;top:26px;left:26px;width:140px;height:140px;background:rgba(0,0,0,.45);border:1px solid rgba(0,229,255,.25);border-radius:4px;overflow:hidden}
#minimapCanvas{width:100%;height:100%}
#damageOverlay{position:absolute;inset:0;box-shadow:inset 0 0 80px rgba(255,0,0,0);pointer-events:none;transition:box-shadow .15s}
#damageOverlay.show{box-shadow:inset 0 0 100px rgba(255,0,0,.35)}
#reloadBar{position:absolute;top:56%;left:50%;transform:translate(-50%,-50%);width:120px;height:4px;background:rgba(255,255,255,.08);border-radius:2px;opacity:0;transition:opacity .2s;overflow:hidden}
#reloadBar.show{opacity:1}
#reloadFill{height:100%;background:#00e5ff;border-radius:2px;width:0%;transition:width .05s linear}
#waveAnnounce{position:absolute;top:28%;left:50%;transform:translate(-50%,-50%);text-align:center;opacity:0;transition:opacity .5s;pointer-events:none}
#waveAnnounce.show{opacity:1}
#waveAnnounce h2{font-family:'Orbitron',monospace;font-size:clamp(2rem,5vw,3.2rem);font-weight:900;color:#ff2d2d;text-shadow:0 0 30px rgba(255,45,45,.5)}
#waveAnnounce p{color:#00e5ff;font-size:.95rem;letter-spacing:.22em;margin-top:.3rem}
#killFeed{position:absolute;top:26px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:3px}
.kill-msg{font-size:.82rem;color:#ff6b4a;letter-spacing:.12em;animation:kfade 2.2s forwards}
@keyframes kfade{0%{opacity:1;transform:translateY(0)}75%{opacity:1}100%{opacity:0;transform:translateY(-8px)}}
#pauseMsg{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Orbitron',monospace;font-size:1.2rem;color:#00e5ff;letter-spacing:.2em;opacity:0;transition:opacity .3s;pointer-events:none}
#pauseMsg.show{opacity:.8}
#gameOver{position:fixed;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;background:rgba(10,10,18,.96);z-index:100}
#gameOver h2{font-family:'Orbitron',monospace;font-size:clamp(2.5rem,6vw,4rem);font-weight:900;color:#ff2d2d;margin-bottom:1.2rem;text-shadow:0 0 30px rgba(255,45,45,.4)}
.go-stats{color:#777;font-size:1.15rem;margin-bottom:2rem;text-align:center;line-height:2.2}
.go-stats span{color:#fff;font-weight:700}
</style>
</head>
<body>

<div id="startScreen">
  <h1>NEON STRIKE</h1>
  <div class="subtitle">Wave Survival FPS</div>
  <button class="start-btn" id="startBtn">ENGAGE</button>
  <div class="controls-info">
    <span>WASD</span> Move &bull; <span>MOUSE</span> Aim &bull; <span>CLICK</span> Fire<br>
    <span>R</span> Reload &bull; <span>SHIFT</span> Sprint &bull; <span>ESC</span> Pause
  </div>
</div>

<div id="hud">
  <div id="crosshair"><div class="ch-dot"></div></div>
  <div id="hitMarker"></div>
  <div id="healthBar">
    <div class="bar-bg"><div class="bar-fill" id="hpFill"></div></div>
    <div class="hp-val" id="hpVal">100</div>
  </div>
  <div id="ammoDisplay">
    <div class="weapon-label">Pulse Rifle</div>
    <div class="ammo-cur" id="ammoCur">30</div>
    <div class="ammo-res" id="ammoRes">/ 120</div>
  </div>
  <div id="scoreDisplay">
    <div class="score-val" id="scoreVal">0</div>
    <div class="wave-val" id="waveVal">WAVE 1</div>
  </div>
  <div id="minimap"><canvas id="minimapCanvas" width="140" height="140"></canvas></div>
  <div id="damageOverlay"></div>
  <div id="reloadBar"><div id="reloadFill"></div></div>
  <div id="waveAnnounce"><h2 id="waveText"></h2><p id="waveSubtext"></p></div>
  <div id="killFeed"></div>
  <div id="pauseMsg">PAUSED — CLICK TO RESUME</div>
</div>

<div id="gameOver">
  <h2>TERMINATED</h2>
  <div class="go-stats" id="goStats"></div>
  <button class="start-btn" id="restartBtn">RESTART</button>
</div>

<script type="importmap">
{
  "imports": {
    "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
    "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
  }
}
</script>
<script type="module">
import * as THREE from 'three';

/* ===== CONSTANTS ===== */
const ARENA=56, WALL_H=4, PLAYER_H=1.6, PLAYER_R=0.4;
const MAG_SIZE=30, FIRE_RATE=110, RELOAD_TIME=1600, BULLET_DMG=25;
const MOVE_SPEED=7.5, SPRINT_MULT=1.65;
const ENEMY_DMG_REG=8, ENEMY_DMG_HEAVY=18;
const ENEMY_HP_REG=30, ENEMY_HP_HEAVY=70;
const ENEMY_SPD_REG=3.8, ENEMY_SPD_HEAVY=2.2;
const ENEMY_ATK_RATE=1.0, ENEMY_ATK_RANGE=2.2, ENEMY_DETECT=28;
const INVULN_TIME=0.35, MAX_ENEMIES=10;

/* ===== STATE ===== */
let gameState='menu';
let scene,camera,renderer,clock;
let playerBody,playerHead;
let weaponGroup,weaponFlash;
let weaponBasePos=new THREE.Vector3(.28,-.22,-.48);
let weaponRecoil=0,weaponBob=0,weaponSwayX=0,weaponSwayY=0;
let ammo=MAG_SIZE,reserveAmmo=120;
let canShoot=true,isReloading=false,reloadStart=0;
let mouseDown=false;
let moveF=false,moveB=false,moveL=false,moveR=false,sprint=false;
let playerHealth=100,invulnTimer=0,screenShake=0;
let score=0,wave=0,totalKills=0;
let enemies=[],wallBoxes=[],pickups=[],particleSystems=[];
let wavePending=false,waveTimer=0;
let mmCtx,hitMarkerTimer=0,damageFlashTimer=0,audioCtx;

/* ===== PRE-CREATED MATERIALS (never create during gameplay) ===== */
// Flash material — reused for all hit flashes
const flashMat = new THREE.MeshStandardMaterial({color:0xffffff,emissive:0xffffff,emissiveIntensity:5});

// Regular enemy materials
const regBodyMat = new THREE.MeshStandardMaterial({color:0x00ff66,emissive:0x00ff66,emissiveIntensity:1.8,metalness:.3,roughness:.5});
const regAccentMat = new THREE.MeshStandardMaterial({color:0xffffff,emissive:0xffffff,emissiveIntensity:4});
const regJointMat = new THREE.MeshStandardMaterial({color:0x004422,emissive:0x00ff66,emissiveIntensity:.3,metalness:.4,roughness:.6});
const regCoreMat = new THREE.MeshStandardMaterial({color:0xffffff,emissive:0xffffff,emissiveIntensity:6});

// Heavy enemy materials
const hvyBodyMat = new THREE.MeshStandardMaterial({color:0xff00aa,emissive:0xff00aa,emissiveIntensity:1.8,metalness:.3,roughness:.5});
const hvyAccentMat = new THREE.MeshStandardMaterial({color:0xffff00,emissive:0xffff00,emissiveIntensity:4});
const hvyJointMat = new THREE.MeshStandardMaterial({color:0x550033,emissive:0xff00aa,emissiveIntensity:.3,metalness:.4,roughness:.6});
const hvyCoreMat = new THREE.MeshStandardMaterial({color:0xffff00,emissive:0xffff00,emissiveIntensity:6});

// Particle materials — one per color, reused
const particleMatGreen = new THREE.MeshBasicMaterial({color:0x44ff88,transparent:true,opacity:1});
const particleMatPink = new THREE.MeshBasicMaterial({color:0xff44ff,transparent:true,opacity:1});

// Shared geometries — create once, reuse everywhere
const sharedGeo = {
  regLeg: new THREE.BoxGeometry(.22,.8,.28),
  hvyLeg: new THREE.BoxGeometry(.24,.85,.3),
  knee: new THREE.SphereGeometry(.06,4,4),
  eye: new THREE.SphereGeometry(.08,6,4),
  hvyEye: new THREE.SphereGeometry(.1,6,4),
  particle: new THREE.BoxGeometry(.1,.1,.1),
  pickup: new THREE.OctahedronGeometry(.25,0),
};

const wallDefs=[
  {x:0,z:-ARENA/2,w:ARENA,d:1.5,h:WALL_H},
  {x:0,z:ARENA/2,w:ARENA,d:1.5,h:WALL_H},
  {x:-ARENA/2,z:0,w:1.5,d:ARENA,h:WALL_H},
  {x:ARENA/2,z:0,w:1.5,d:ARENA,h:WALL_H},
  {x:0,z:0,w:5,d:5,h:3.2},
  {x:-13,z:-10,w:8,d:1,h:3},{x:-17,z:-6,w:1,d:8,h:3},
  {x:13,z:-10,w:8,d:1,h:3},{x:17,z:-6,w:1,d:8,h:3},
  {x:-13,z:10,w:8,d:1,h:3},{x:-17,z:6,w:1,d:8,h:3},
  {x:13,z:10,w:8,d:1,h:3},{x:17,z:6,w:1,d:8,h:3},
  {x:-23,z:0,w:1,d:10,h:3},{x:23,z:0,w:1,d:10,h:3},
  {x:0,z:-19,w:10,d:1,h:3},{x:0,z:19,w:10,d:1,h:3},
  {x:-8,z:-20,w:2,d:2,h:3},{x:8,z:-20,w:2,d:2,h:3},
  {x:-8,z:20,w:2,d:2,h:3},{x:8,z:20,w:2,d:2,h:3},
  {x:-6,z:-5,w:3,d:1,h:2.5},{x:6,z:5,w:3,d:1,h:2.5},
  {x:-6,z:5,w:1,d:3,h:2.5},{x:6,z:-5,w:1,d:3,h:2.5},
];

const spawnPoints=[
  [-24,-24],[24,-24],[-24,24],[24,24],
  [-24,0],[24,0],[0,-24],[0,24],
  [-18,-18],[18,-18],[-18,18],[18,18],
  [-12,0],[12,0],[0,-12],[0,12],
];

/* ===== AUDIO ===== */
function initAudio(){audioCtx=new(window.AudioContext||window.webkitAudioContext)()}
function playSound(type){
  if(!audioCtx)return;try{audioCtx.resume()}catch(e){}
  const t=audioCtx.currentTime;
  switch(type){
    case'shoot':{const l=.09,b=audioCtx.createBuffer(1,audioCtx.sampleRate*l|0,audioCtx.sampleRate),d=b.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,2.5);const s=audioCtx.createBufferSource();s.buffer=b;const f=audioCtx.createBiquadFilter();f.type='lowpass';f.frequency.setValueAtTime(2200,t);f.frequency.exponentialRampToValueAtTime(150,t+l);const g=audioCtx.createGain();g.gain.setValueAtTime(.25,t);g.gain.exponentialRampToValueAtTime(.001,t+l);s.connect(f);f.connect(g);g.connect(audioCtx.destination);s.start(t);break}
    case'hit':{const o=audioCtx.createOscillator();o.type='sine';o.frequency.setValueAtTime(900,t);o.frequency.exponentialRampToValueAtTime(200,t+.04);const g=audioCtx.createGain();g.gain.setValueAtTime(.12,t);g.gain.exponentialRampToValueAtTime(.001,t+.04);o.connect(g);g.connect(audioCtx.destination);o.start(t);o.stop(t+.05);break}
    case'kill':{const o=audioCtx.createOscillator();o.type='sawtooth';o.frequency.setValueAtTime(500,t);o.frequency.exponentialRampToValueAtTime(80,t+.25);const g=audioCtx.createGain();g.gain.setValueAtTime(.15,t);g.gain.exponentialRampToValueAtTime(.001,t+.25);o.connect(g);g.connect(audioCtx.destination);o.start(t);o.stop(t+.26);break}
    case'damage':{const l=.12,b=audioCtx.createBuffer(1,audioCtx.sampleRate*l|0,audioCtx.sampleRate),d=b.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,1.8)*.6;const s=audioCtx.createBufferSource();s.buffer=b;const f=audioCtx.createBiquadFilter();f.type='lowpass';f.frequency.value=350;const g=audioCtx.createGain();g.gain.setValueAtTime(.25,t);g.gain.exponentialRampToValueAtTime(.001,t+l);s.connect(f);f.connect(g);g.connect(audioCtx.destination);s.start(t);break}
    case'reload':{[0,.25,.5].forEach((o,i)=>{const c=audioCtx.createOscillator();c.type='square';c.frequency.value=250+i*80;const g=audioCtx.createGain();g.gain.setValueAtTime(.06,t+o);g.gain.exponentialRampToValueAtTime(.001,t+o+.04);c.connect(g);g.connect(audioCtx.destination);c.start(t+o);c.stop(t+o+.05)});break}
    case'pickup':{const o=audioCtx.createOscillator();o.type='sine';o.frequency.setValueAtTime(400,t);o.frequency.exponentialRampToValueAtTime(900,t+.12);const g=audioCtx.createGain();g.gain.setValueAtTime(.12,t);g.gain.exponentialRampToValueAtTime(.001,t+.12);o.connect(g);g.connect(audioCtx.destination);o.start(t);o.stop(t+.13);break}
    case'empty':{const o=audioCtx.createOscillator();o.type='square';o.frequency.value=120;const g=audioCtx.createGain();g.gain.setValueAtTime(.05,t);g.gain.exponentialRampToValueAtTime(.001,t+.03);o.connect(g);g.connect(audioCtx.destination);o.start(t);o.stop(t+.04);break}
  }
}

/* ===== SCENE SETUP ===== */
function init(){
  scene=new THREE.Scene();
  scene.background=new THREE.Color(0x1a1a2e);
  scene.fog=new THREE.FogExp2(0x1a1a2e,0.012);

  camera=new THREE.PerspectiveCamera(75,innerWidth/innerHeight,.1,80);

  renderer=new THREE.WebGLRenderer({antialias:false,powerPreference:'high-performance'});
  renderer.setSize(innerWidth,innerHeight);
  renderer.setPixelRatio(Math.min(devicePixelRatio,1.5));
  renderer.toneMapping=THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure=1.8;
  document.body.appendChild(renderer.domElement);

  clock=new THREE.Clock();

  playerBody=new THREE.Object3D();
  playerHead=new THREE.Object3D();
  playerHead.position.y=PLAYER_H;
  playerBody.add(playerHead);
  playerHead.add(camera);
  scene.add(playerBody);
  playerBody.position.set(0,0,20);

  /* Lighting — only 4 scene lights total, no per-object lights */
  scene.add(new THREE.AmbientLight(0x9999bb,1.4));
  scene.add(new THREE.HemisphereLight(0x6688cc,0x443322,.8));
  const dir=new THREE.DirectionalLight(0xffeedd,.8);
  dir.position.set(10,25,10);
  scene.add(dir);

  // Just 4 colored accent lights — no per-enemy, no per-pickup
  const pts=[
    {pos:[-20,3.5,-20],col:0xff2d2d,int:2.5,dist:40},
    {pos:[20,3.5,-20],col:0x00e5ff,int:2.5,dist:40},
    {pos:[-20,3.5,20],col:0x00e5ff,int:2.5,dist:40},
    {pos:[20,3.5,20],col:0xff2d2d,int:2.5,dist:40},
  ];
  pts.forEach(p=>{
    const pl=new THREE.PointLight(p.col,p.int,p.dist);
    pl.position.set(...p.pos);scene.add(pl);
  });

  buildMap();
  createWeapon();
  setupMinimap();
  setupControls();
  animate();
}

/* ===== MAP ===== */
function buildMap(){
  const floorTex=makeFloorTex();
  const floorMat=new THREE.MeshLambertMaterial({map:floorTex,color:0x333350});
  const floor=new THREE.Mesh(new THREE.PlaneGeometry(ARENA,ARENA),floorMat);
  floor.rotation.x=-Math.PI/2;scene.add(floor);

  const ceilMat=new THREE.MeshLambertMaterial({color:0x181828});
  const ceil=new THREE.Mesh(new THREE.PlaneGeometry(ARENA,ARENA),ceilMat);
  ceil.rotation.x=Math.PI/2;ceil.position.y=WALL_H;scene.add(ceil);

  const wallMat=new THREE.MeshLambertMaterial({color:0x303058});
  const glowCyan=new THREE.MeshBasicMaterial({color:0x00e5ff});
  const glowRed=new THREE.MeshBasicMaterial({color:0xff2d2d});

  wallDefs.forEach((w,i)=>{
    const geo=new THREE.BoxGeometry(Math.max(.1,w.w),Math.max(.1,w.h),Math.max(.1,w.d));
    const mesh=new THREE.Mesh(geo,wallMat);
    mesh.position.set(w.x,w.h/2,w.z);scene.add(mesh);

    const sGeo=new THREE.BoxGeometry(Math.max(.1,w.w+.02),.08,Math.max(.1,w.d+.02));
    const strip=new THREE.Mesh(sGeo,i%2===0?glowCyan:glowRed);
    strip.position.set(w.x,.04,w.z);scene.add(strip);

    wallBoxes.push({minX:w.x-w.w/2,maxX:w.x+w.w/2,minZ:w.z-w.d/2,maxZ:w.z+w.d/2});
  });

  const lGeo=new THREE.PlaneGeometry(1.5,.4);
  const lC=new THREE.MeshBasicMaterial({color:0x00e5ff,side:THREE.DoubleSide});
  const lR=new THREE.MeshBasicMaterial({color:0xff2d2d,side:THREE.DoubleSide});
  for(let x=-24;x<=24;x+=8)for(let z=-24;z<=24;z+=8){
    const m=new THREE.Mesh(lGeo,(x+z)%16===0?lC:lR);
    m.rotation.x=Math.PI/2;m.position.set(x,WALL_H-.01,z);scene.add(m);
  }
}

function makeFloorTex(){
  const c=document.createElement('canvas');c.width=128;c.height=128;
  const ctx=c.getContext('2d');ctx.fillStyle='#1a1a30';ctx.fillRect(0,0,128,128);
  ctx.strokeStyle='#2a2a4e';ctx.lineWidth=1;
  for(let i=0;i<=128;i+=32){ctx.beginPath();ctx.moveTo(i,0);ctx.lineTo(i,128);ctx.stroke();ctx.beginPath();ctx.moveTo(0,i);ctx.lineTo(128,i);ctx.stroke()}
  const tex=new THREE.CanvasTexture(c);tex.wrapS=tex.wrapT=THREE.RepeatWrapping;tex.repeat.set(14,14);return tex;
}

/* ===== WEAPON ===== */
function createWeapon(){
  weaponGroup=new THREE.Group();
  const dk=new THREE.MeshLambertMaterial({color:0x1a1a1a});
  const md=new THREE.MeshLambertMaterial({color:0x2a2a2a});
  const ac=new THREE.MeshBasicMaterial({color:0xff2d2d});

  weaponGroup.add(new THREE.Mesh(new THREE.BoxGeometry(.055,.075,.42),dk));
  const rail=new THREE.Mesh(new THREE.BoxGeometry(.04,.015,.3),md);rail.position.set(0,.046,-.02);weaponGroup.add(rail);
  const barrel=new THREE.Mesh(new THREE.CylinderGeometry(.013,.016,.28,6),dk);barrel.rotation.x=Math.PI/2;barrel.position.set(0,.012,-.32);weaponGroup.add(barrel);
  const tip=new THREE.Mesh(new THREE.TorusGeometry(.018,.004,6,12),ac);tip.position.set(0,.012,-.46);weaponGroup.add(tip);
  const mag=new THREE.Mesh(new THREE.BoxGeometry(.03,.11,.05),md);mag.position.set(0,-.075,.04);weaponGroup.add(mag);
  const grip=new THREE.Mesh(new THREE.BoxGeometry(.035,.09,.04),dk);grip.position.set(0,-.06,.14);grip.rotation.x=.25;weaponGroup.add(grip);
  const sight=new THREE.Mesh(new THREE.BoxGeometry(.015,.028,.025),md);sight.position.set(0,.065,-.08);weaponGroup.add(sight);
  const glow=new THREE.Mesh(new THREE.BoxGeometry(.058,.004,.18),ac);glow.position.set(0,.039,.04);weaponGroup.add(glow);

  weaponFlash=new THREE.PointLight(0xff6b4a,0,5);weaponFlash.position.set(0,0,-.5);weaponGroup.add(weaponFlash);
  const fGeo=new THREE.SphereGeometry(.04,4,4);
  const fMat=new THREE.MeshBasicMaterial({color:0xffaa44,transparent:true,opacity:0});
  const fMesh=new THREE.Mesh(fGeo,fMat);fMesh.position.set(0,0,-.48);fMesh.name='flashMesh';weaponGroup.add(fMesh);

  weaponGroup.position.copy(weaponBasePos);camera.add(weaponGroup);
}

/* ===== ENEMIES — pre-created materials, NO per-enemy lights ===== */
function createEnemy(type,pos){
  const g=new THREE.Group();
  const isH=type==='heavy';
  const bMat=isH?hvyBodyMat:regBodyMat;
  const aMat=isH?hvyAccentMat:regAccentMat;
  const jMat=isH?hvyJointMat:regJointMat;
  const cMat=isH?hvyCoreMat:regCoreMat;

  const tw=isH?1:.8, th=isH?1.4:1.15, td=isH?.65:.5;

  // Torso
  const torso=new THREE.Mesh(new THREE.BoxGeometry(tw,th,td),bMat);
  torso.position.y=isH?1.35:1.2;torso.userData.matGroup='body';g.add(torso);

  // Core panel
  const ch=isH?.35:.25;
  const core=new THREE.Mesh(new THREE.BoxGeometry(tw*.5,ch,td+.02),cMat);
  core.position.y=isH?1.45:1.3;core.userData.matGroup='accent';g.add(core);

  // Head
  const hw=isH?.6:.48, hh=isH?.55:.45, hd=isH?.6:.48;
  const head=new THREE.Mesh(new THREE.BoxGeometry(hw,hh,hd),bMat);
  head.position.y=isH?2.2:2.0;head.userData.matGroup='body';g.add(head);

  // Visor
  const visor=new THREE.Mesh(new THREE.BoxGeometry(hw*.85,.08,hd+.02),aMat);
  visor.position.set(0,isH?2.22:2.02,0);visor.userData.matGroup='accent';g.add(visor);

  // Eyes
  const eyeGeo=isH?sharedGeo.hvyEye:sharedGeo.eye;
  const eyeY=isH?2.22:2.02, eyeZ=-(hd/2+.01);
  const lEye=new THREE.Mesh(eyeGeo,aMat);lEye.position.set(-.12,eyeY,eyeZ);lEye.userData.matGroup='accent';g.add(lEye);
  const rEye=new THREE.Mesh(eyeGeo,aMat);rEye.position.set(.12,eyeY,eyeZ);rEye.userData.matGroup='accent';g.add(rEye);

  // Legs
  const legGeo=isH?sharedGeo.hvyLeg:sharedGeo.regLeg;
  const ll=new THREE.Mesh(legGeo,jMat);ll.position.set(-.2,.4,0);ll.userData.matGroup='joint';g.add(ll);
  const rl=new THREE.Mesh(legGeo,jMat);rl.position.set(.2,.4,0);rl.userData.matGroup='joint';g.add(rl);

  // Knees
  const lK=new THREE.Mesh(sharedGeo.knee,aMat);lK.position.set(-.2,.75,0);lK.userData.matGroup='accent';g.add(lK);
  const rK=new THREE.Mesh(sharedGeo.knee,aMat);rK.position.set(.2,.75,0);rK.userData.matGroup='accent';g.add(rK);

  // Shoulders
  const sw=isH?.35:.22;
  const lS=new THREE.Mesh(new THREE.BoxGeometry(sw,.12,td*.9),aMat);lS.position.set(-(tw/2+sw/2-.02),isH?1.9:1.7,0);lS.userData.matGroup='accent';g.add(lS);
  const rS=new THREE.Mesh(new THREE.BoxGeometry(sw,.12,td*.9),aMat);rS.position.set((tw/2+sw/2-.02),isH?1.9:1.7,0);rS.userData.matGroup='accent';g.add(rS);

  if(isH){
    const pGeo=new THREE.BoxGeometry(.25,.3,.4);
    const lP=new THREE.Mesh(pGeo,bMat);lP.position.set(-.65,1.9,0);lP.userData.matGroup='body';g.add(lP);
    const rP=new THREE.Mesh(pGeo,bMat);rP.position.set(.65,1.9,0);rP.userData.matGroup='body';g.add(rP);
  }

  // NO per-enemy point light — emissive materials make them glow without render cost

  g.position.copy(pos);scene.add(g);

  return{group:g,type,
    health:isH?ENEMY_HP_HEAVY:ENEMY_HP_REG,
    maxHealth:isH?ENEMY_HP_HEAVY:ENEMY_HP_REG,
    speed:isH?ENEMY_SPD_HEAVY:ENEMY_SPD_REG,
    damage:isH?ENEMY_DMG_HEAVY:ENEMY_DMG_REG,
    attackCooldown:0,attackRate:isH?1.4:ENEMY_ATK_RATE,
    flashTimer:0,
    bodyMat:bMat,jointMat:jMat,accentMat:aMat,coreMat:cMat,
    isFlashing:false
  };
}

function spawnWave(n){
  const regC=3+n*2, hvyC=Math.max(0,Math.floor((n-1)/1.5));
  for(let i=0;i<regC+hvyC&&enemies.length<MAX_ENEMIES;i++){
    const type=i>=regC?'heavy':'regular';
    const sp=spawnPoints[Math.floor(Math.random()*spawnPoints.length)];
    const px=sp[0]+(Math.random()-.5)*4, pz=sp[1]+(Math.random()-.5)*4;
    const pos=new THREE.Vector3(px,0,pz);
    if(pos.distanceTo(playerBody.position)<12){pos.x=-pos.x;pos.z=-pos.z}
    if(!collidesWithWalls(pos,.6))enemies.push(createEnemy(type,pos));
  }
}

function killEnemy(enemy){
  score+=enemy.type==='heavy'?200:100;totalKills++;
  createDeathParticles(enemy.group.position.clone(),enemy.type==='heavy');
  scene.remove(enemy.group);
  enemies=enemies.filter(e=>e!==enemy);
  playSound('kill');addKillMsg(enemy.type);
  if(Math.random()<.3)spawnPickup(enemy.group.position.clone());
}

function createDeathParticles(pos,big){
  const g=new THREE.Group();
  const count=big?10:6;
  const mat=big?particleMatPink:particleMatGreen;
  for(let i=0;i<count;i++){
    const m=new THREE.Mesh(sharedGeo.particle,mat);
    m.position.set(pos.x+(Math.random()-.5)*.5,pos.y+Math.random()*1.5,pos.z+(Math.random()-.5)*.5);
    m.userData.vel=new THREE.Vector3((Math.random()-.5)*5,Math.random()*4+1,(Math.random()-.5)*5);
    m.userData.life=.5+Math.random()*.4;
    g.add(m);
  }
  scene.add(g);particleSystems.push(g);
}

/* ===== PICKUPS — no per-pickup lights ===== */
function spawnPickup(pos){
  const mat=new THREE.MeshBasicMaterial({color:0x00ff88});
  const m=new THREE.Mesh(sharedGeo.pickup,mat);
  m.position.set(pos.x,.5,pos.z);scene.add(m);
  pickups.push({mesh:m,amount:25});
}

/* ===== COLLISION ===== */
function collidesWithWalls(pos,r){
  for(const w of wallBoxes)if(pos.x+r>w.minX&&pos.x-r<w.maxX&&pos.z+r>w.minZ&&pos.z-r<w.maxZ)return true;
  return false;
}
function tryMove(cur,des,r){
  if(!collidesWithWalls(des,r))return des.clone();
  let tx=new THREE.Vector3(des.x,cur.y,cur.z);if(!collidesWithWalls(tx,r))return tx;
  let tz=new THREE.Vector3(cur.x,cur.y,des.z);if(!collidesWithWalls(tz,r))return tz;
  return cur.clone();
}
function findEnemyByObj(obj){let c=obj;while(c){const e=enemies.find(en=>en.group===c);if(e)return e;c=c.parent}return null}

/* ===== SHOOTING ===== */
function shoot(){
  if(!canShoot||isReloading)return;
  if(ammo<=0){playSound('empty');if(reserveAmmo>0)reload();return}
  canShoot=false;ammo--;
  setTimeout(()=>canShoot=true,FIRE_RATE);
  playSound('shoot');
  weaponFlash.intensity=3;
  const fm=weaponGroup.getObjectByName('flashMesh');if(fm)fm.material.opacity=.8;
  setTimeout(()=>{weaponFlash.intensity=0;if(fm)fm.material.opacity=0},40);
  weaponRecoil=.06;

  const rc=new THREE.Raycaster();rc.setFromCamera(new THREE.Vector2(0,0),camera);rc.far=60;
  const meshes=[];enemies.forEach(e=>e.group.traverse(c=>{if(c.isMesh)meshes.push(c)}));
  const hits=rc.intersectObjects(meshes,false);
  if(hits.length>0){
    const he=findEnemyByObj(hits[0].object);
    if(he){he.health-=BULLET_DMG;he.flashTimer=.1;playSound('hit');hitMarkerTimer=.1;if(he.health<=0)killEnemy(he)}
  }
  updateHUD();if(ammo<=0&&reserveAmmo>0)reload();
}

function reload(){
  if(isReloading||ammo===MAG_SIZE||reserveAmmo<=0)return;
  isReloading=true;reloadStart=performance.now();playSound('reload');
  document.getElementById('reloadBar').classList.add('show');
}
function updateReload(){
  if(!isReloading)return;
  const pct=Math.min(1,(performance.now()-reloadStart)/RELOAD_TIME);
  document.getElementById('reloadFill').style.width=(pct*100)+'%';
  if(pct>=1){const n=MAG_SIZE-ammo,a=Math.min(n,reserveAmmo);ammo+=a;reserveAmmo-=a;isReloading=false;document.getElementById('reloadBar').classList.remove('show');document.getElementById('reloadFill').style.width='0%';updateHUD()}
}

/* ===== CONTROLS ===== */
function setupControls(){
  document.addEventListener('keydown',e=>{if(gameState!=='playing')return;switch(e.code){case'KeyW':moveF=true;break;case'KeyS':moveB=true;break;case'KeyA':moveL=true;break;case'KeyD':moveR=true;break;case'ShiftLeft':case'ShiftRight':sprint=true;break;case'KeyR':reload();break}});
  document.addEventListener('keyup',e=>{switch(e.code){case'KeyW':moveF=false;break;case'KeyS':moveB=false;break;case'KeyA':moveL=false;break;case'KeyD':moveR=false;break;case'ShiftLeft':case'ShiftRight':sprint=false;break}});
  document.addEventListener('mousedown',e=>{if(e.button===0){mouseDown=true;if(gameState==='playing')shoot()}});
  document.addEventListener('mouseup',e=>{if(e.button===0)mouseDown=false});
  document.addEventListener('mousemove',e=>{
    if(gameState!=='playing'||!document.pointerLockElement)return;
    playerBody.rotation.y-=e.movementX*.002;
    playerHead.rotation.x=Math.max(-1.4,Math.min(1.4,playerHead.rotation.x-e.movementY*.002));
    weaponSwayX-=e.movementX*.0004;weaponSwayY-=e.movementY*.0003;
  });
  document.addEventListener('pointerlockchange',()=>{
    if(document.pointerLockElement===renderer.domElement){if(gameState==='paused')gameState='playing'}
    else{if(gameState==='playing')gameState='paused'}
  });
  renderer.domElement.addEventListener('click',()=>{if(gameState==='paused')renderer.domElement.requestPointerLock()});
}

/* ===== MINIMAP ===== */
function setupMinimap(){mmCtx=document.getElementById('minimapCanvas').getContext('2d')}
function drawMinimap(){
  const c=mmCtx,sz=140,sc=sz/ARENA;c.clearRect(0,0,sz,sz);
  c.fillStyle='rgba(10,10,18,.6)';c.fillRect(0,0,sz,sz);
  c.fillStyle='rgba(0,229,255,.2)';
  wallBoxes.forEach(w=>{c.fillRect((w.minX+ARENA/2)*sc,(w.minZ+ARENA/2)*sc,(w.maxX-w.minX)*sc,(w.maxZ-w.minZ)*sc)});
  enemies.forEach(e=>{c.fillStyle=e.type==='heavy'?'#ff00aa':'#00ff66';c.beginPath();c.arc((e.group.position.x+ARENA/2)*sc,(e.group.position.z+ARENA/2)*sc,2.5,0,Math.PI*2);c.fill()});
  pickups.forEach(p=>{c.fillStyle='#00ff88';c.fillRect((p.mesh.position.x+ARENA/2)*sc-1.5,(p.mesh.position.z+ARENA/2)*sc-1.5,3,3)});
  const px=(playerBody.position.x+ARENA/2)*sc,pz=(playerBody.position.z+ARENA/2)*sc;
  c.fillStyle='#00e5ff';c.beginPath();c.arc(px,pz,3,0,Math.PI*2);c.fill();
  const dx=Math.sin(playerBody.rotation.y)*8,dz=Math.cos(playerBody.rotation.y)*8;
  c.strokeStyle='#00e5ff';c.lineWidth=1.5;c.beginPath();c.moveTo(px,pz);c.lineTo(px-dx,pz-dz);c.stroke();
}

/* ===== HUD ===== */
function updateHUD(){
  document.getElementById('hpFill').style.width=Math.max(0,playerHealth)+'%';
  document.getElementById('hpVal').textContent=Math.max(0,Math.round(playerHealth));
  document.getElementById('ammoCur').textContent=ammo;
  document.getElementById('ammoRes').textContent='/ '+reserveAmmo;
  document.getElementById('scoreVal').textContent=score;
  document.getElementById('waveVal').textContent='WAVE '+wave;
}
function addKillMsg(type){
  const el=document.createElement('div');el.className='kill-msg';
  el.textContent=type==='heavy'?'Heavy Drone Eliminated +200':'Drone Eliminated +100';
  document.getElementById('killFeed').appendChild(el);setTimeout(()=>el.remove(),2300);
}
function showWaveAnnounce(n,count){
  const el=document.getElementById('waveAnnounce');
  document.getElementById('waveText').textContent='WAVE '+n;
  document.getElementById('waveSubtext').textContent=count+' HOSTILES INCOMING';
  el.classList.add('show');setTimeout(()=>el.classList.remove('show'),2500);
}

/* ===== GAME STATE ===== */
function startGame(){
  document.getElementById('startScreen').style.display='none';
  document.getElementById('hud').style.display='block';
  document.getElementById('gameOver').style.display='none';
  gameState='playing';if(!audioCtx)initAudio();
  renderer.domElement.requestPointerLock();resetGame();
}
function resetGame(){
  playerHealth=100;ammo=MAG_SIZE;reserveAmmo=120;score=0;wave=0;totalKills=0;
  canShoot=true;isReloading=false;mouseDown=false;
  moveF=moveB=moveL=moveR=sprint=false;invulnTimer=0;screenShake=0;
  playerBody.position.set(0,0,20);playerBody.rotation.y=0;playerHead.rotation.x=0;
  enemies.forEach(e=>scene.remove(e.group));enemies=[];
  pickups.forEach(p=>scene.remove(p.mesh));pickups=[];
  particleSystems.forEach(g=>scene.remove(g));particleSystems=[];
  document.getElementById('reloadBar').classList.remove('show');
  document.getElementById('reloadFill').style.width='0%';
  document.getElementById('pauseMsg').classList.remove('show');
  wavePending=true;waveTimer=1.5;updateHUD();
}
function gameOver(){
  gameState='gameover';document.exitPointerLock();
  document.getElementById('gameOver').style.display='flex';
  document.getElementById('goStats').innerHTML=`Score: <span>${score}</span><br>Wave Reached: <span>${wave}</span><br>Enemies Destroyed: <span>${totalKills}</span>`;
}

/* ===== MAIN LOOP ===== */
function animate(){
  requestAnimationFrame(animate);
  const dt=Math.min(clock.getDelta(),.05);
  if(gameState==='playing'){
    updatePlayer(dt);updateWeapon(dt);updateReload();
    updateEnemies(dt);updateParticles(dt);updatePickups(dt);
    updateWaveLogic(dt);updateDamageFlash(dt);updateHitMarker(dt);
    if(mouseDown&&canShoot&&!isReloading)shoot();
    drawMinimap();
  }
  const pm=document.getElementById('pauseMsg');
  if(gameState==='paused')pm.classList.add('show');else pm.classList.remove('show');
  renderer.render(scene,camera);
}

function updatePlayer(dt){
  const spd=MOVE_SPEED*(sprint?SPRINT_MULT:1);
  const dir=new THREE.Vector3();
  if(moveF)dir.z-=1;if(moveB)dir.z+=1;if(moveL)dir.x-=1;if(moveR)dir.x+=1;
  if(dir.length()>0){
    dir.normalize();dir.applyAxisAngle(new THREE.Vector3(0,1,0),playerBody.rotation.y);
    const np=playerBody.position.clone().add(dir.multiplyScalar(spd*dt));
    playerBody.position.copy(tryMove(playerBody.position,np,PLAYER_R));
  }
  camera.fov+=((sprint&&dir.length()>0?85:75)-camera.fov)*8*dt;camera.updateProjectionMatrix();
  if(invulnTimer>0)invulnTimer-=dt;
  if(screenShake>0){
    playerHead.position.x=(Math.random()-.5)*screenShake;
    playerHead.position.y=PLAYER_H+(Math.random()-.5)*screenShake;
    screenShake*=Math.pow(.05,dt);
    if(screenShake<.001){screenShake=0;playerHead.position.x=0;playerHead.position.y=PLAYER_H}
  }
}

function updateWeapon(dt){
  weaponRecoil*=Math.pow(.001,dt);if(weaponRecoil<.001)weaponRecoil=0;
  weaponSwayX*=Math.pow(.02,dt);weaponSwayY*=Math.pow(.02,dt);
  const isM=moveF||moveB||moveL||moveR;
  weaponBob+=dt*(isM?(sprint?14:10):1.5);
  const bx=isM?Math.cos(weaponBob*.5)*.006:Math.sin(weaponBob)*.001;
  const by=isM?Math.sin(weaponBob)*.008:Math.sin(weaponBob)*.002;
  const rd=isReloading?-.12:0;
  weaponGroup.position.set(weaponBasePos.x+bx+weaponSwayX,weaponBasePos.y+by+weaponSwayY+rd-weaponRecoil*.3,weaponBasePos.z-weaponRecoil);
  weaponGroup.rotation.x=-weaponRecoil*1.5+weaponSwayY;weaponGroup.rotation.y=weaponSwayX*2;
}

function updateEnemies(dt){
  enemies.forEach(e=>{
    /* Hit flash — swap materials on existing meshes, NO new allocations */
    if(e.flashTimer>0){
      e.flashTimer-=dt;
      if(!e.isFlashing){
        e.isFlashing=true;
        e.group.traverse(c=>{if(c.isMesh)c.material=flashMat});
      }
    }else if(e.isFlashing){
      e.isFlashing=false;
      e.group.traverse(c=>{
        if(!c.isMesh)return;
        const g=c.userData.matGroup;
        if(g==='body')c.material=e.bodyMat;
        else if(g==='accent')c.material=e.accentMat;
        else if(g==='joint')c.material=e.jointMat;
        else c.material=e.bodyMat;
      });
    }

    const toP=new THREE.Vector3().subVectors(playerBody.position,e.group.position);toP.y=0;
    const dist=toP.length();
    if(dist>.1)e.group.lookAt(playerBody.position.x,e.group.position.y,playerBody.position.z);

    if(dist<ENEMY_DETECT&&dist>ENEMY_ATK_RANGE){
      toP.normalize();const np=e.group.position.clone().add(toP.multiplyScalar(e.speed*dt));
      e.group.position.copy(tryMove(e.group.position,np,.5));
    }

    if(dist<ENEMY_ATK_RANGE){
      e.attackCooldown-=dt;
      if(e.attackCooldown<=0){
        e.attackCooldown=e.attackRate;
        if(invulnTimer<=0){
          playerHealth-=e.damage;invulnTimer=INVULN_TIME;screenShake=.08;damageFlashTimer=.2;playSound('damage');
          if(playerHealth<=0){playerHealth=0;updateHUD();gameOver()}
        }
      }
    }else{e.attackCooldown=Math.max(0,e.attackCooldown-dt)}

    e.group.position.y=Math.sin(performance.now()*.005+e.group.id)*.03;
  });
}

function updateParticles(dt){
  for(let i=particleSystems.length-1;i>=0;i--){
    const g=particleSystems[i];let dead=true;
    g.children.forEach(p=>{
      if(p.userData.life>0){
        p.userData.life-=dt;p.position.addScaledVector(p.userData.vel,dt);
        p.userData.vel.y-=9.8*dt;p.material.opacity=Math.max(0,p.userData.life);
        p.scale.multiplyScalar(.97);dead=false;
      }
    });
    if(dead){scene.remove(g);particleSystems.splice(i,1)}
  }
}

function updatePickups(dt){
  for(let i=pickups.length-1;i>=0;i--){
    const p=pickups[i];p.mesh.rotation.y+=2*dt;
    p.mesh.position.y=.5+Math.sin(performance.now()*.003)*.15;
    if(playerBody.position.distanceTo(p.mesh.position)<1.5){
      playerHealth=Math.min(100,playerHealth+p.amount);scene.remove(p.mesh);pickups.splice(i,1);
      playSound('pickup');updateHUD();
    }
  }
}

function updateWaveLogic(dt){
  if(wavePending){waveTimer-=dt;if(waveTimer<=0){wavePending=false;wave++;const c=3+wave*2+Math.max(0,Math.floor((wave-1)/1.5));spawnWave(wave);showWaveAnnounce(wave,Math.min(c,MAX_ENEMIES));updateHUD()}return}
  if(enemies.length===0){wavePending=true;waveTimer=2.5}
}
function updateDamageFlash(dt){const o=document.getElementById('damageOverlay');if(damageFlashTimer>0){damageFlashTimer-=dt;o.classList.add('show')}else o.classList.remove('show')}
function updateHitMarker(dt){const e=document.getElementById('hitMarker');if(hitMarkerTimer>0){hitMarkerTimer-=dt;e.classList.add('show')}else e.classList.remove('show')}

document.getElementById('startBtn').addEventListener('click',startGame);
document.getElementById('restartBtn').addEventListener('click',startGame);
window.addEventListener('resize',()=>{if(!camera||!renderer)return;camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();renderer.setSize(innerWidth,innerHeight)});

init();
</script>
</body>
