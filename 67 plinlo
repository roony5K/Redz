            var lv=upgLevels[u.id],maxed=lv>=u.max,cost=maxed?'-':fmt(u.costs[lv]),canBuy=!maxed&&(balance>=u.costs[lv]||adminStates.infiniteMoney);
            var div=document.createElement('div');div.className='shop-item';var dots='';for(var d=0;d<u.max;d++)dots+='<div class="lvl-dot'+(d<lv?' filled':'')+'"></div>';
            div.innerHTML='<div class="shop-icon" style="background:'+hr(u.color,.15)+';color:'+u.color+'"><i class="fas '+u.icon+'"></i></div><div class="shop-info"><div class="shop-name">'+u.name+'</div><div class="shop-desc">'+u.desc+'</div><div class="lvl-dots">'+dots+'</div></div><button class="shop-buy'+(maxed?' owned':'')+'" '+(!canBuy?'disabled':'')+'>'+(maxed?'MAX':'$'+cost)+'</button>';
            div.querySelector('.shop-buy').addEventListener('click',function(){var l2=upgLevels[u.id];if(l2>=u.max||(balance<u.costs[l2]&&!adminStates.infiniteMoney))return;if(!adminStates.infiniteMoney)balance-=u.costs[l2];upgLevels[u.id]++;toast(u.name+' Lv.'+upgLevels[u.id],true);updateUI();});
            list.appendChild(div);
        })(UPGRADES[i]);}
    }

    function renderEndgameShop(){
        var list=document.getElementById('endgameShop');list.innerHTML='';
        for(var i=0;i<ENDGAME.length;i++){(function(e){
            var owned=endgamePurchased[e.id],canBuy=!owned&&(balance>=e.cost||adminStates.infiniteMoney);
            var div=document.createElement('div');div.className='shop-item endgame';
            div.innerHTML='<div class="shop-icon" style="background:'+hr(e.color,.12)+';color:'+e.color+'"><i class="fas '+e.icon+'"></i></div><div class="shop-info"><div class="shop-name" style="color:'+e.color+'">'+e.name+'</div><div class="shop-desc">'+e.desc+'</div></div><button class="shop-buy endgame-buy'+(owned?' owned':'')+'" '+(!canBuy?'disabled':'')+'>'+(owned?'OWNED':'$'+fmt(e.cost))+'</button>';
            div.querySelector('.shop-buy').addEventListener('click',function(){if(endgamePurchased[e.id]||(balance<e.cost&&!adminStates.infiniteMoney))return;if(!adminStates.infiniteMoney)balance-=e.cost;endgamePurchased[e.id]=true;toast(e.name+' activated!','admin');updateUI();});
            list.appendChild(div);
        })(ENDGAME[i]);}
    }

    /* ===== CODE HANDLER ===== */
    function handleCode(raw){
        var code=raw.trim();if(!code)return;
        if(code===ADMIN_CODE){openAdminPanel();codeInput.value='';toast('Admin panel unlocked!','admin');return;}
        var lower=code.toLowerCase();var entry=CODES[lower];
        if(!entry){toast('Invalid code','');codeInput.value='';return;}
        if(entry.nl){entry.fn();toast(entry.msg,entry.ok!==undefined?entry.ok:true);}
        else{useCode(lower,entry.msg,entry.fn);}
        codeInput.value='';updateUI();
    }

    /* ===== ADMIN PANEL ===== */
    function openAdminPanel(){
        adminOpen=true;
        var ov=document.createElement('div');ov.className='admin-overlay';ov.id='adminOverlay';
        ov.addEventListener('click',function(e){if(e.target===ov)closeAdminPanel();});
        var modal=document.createElement('div');modal.className='admin-modal';
        modal.innerHTML=
            '<div class="admin-header"><div class="admin-title"><i class="fas fa-shield-halved" style="margin-right:8px"></i>ADMIN</div><button class="admin-close" id="adminClose"><i class="fas fa-xmark"></i></button></div>'+
            '<div class="admin-section"><div class="admin-section-title"><i class="fas fa-coins" style="margin-right:4px"></i>Money</div>'+
            '<div class="admin-row"><input class="admin-input" id="admSetBal" type="number" placeholder="Set balance..."><button class="admin-btn go" id="admSetBalBtn">Set</button></div>'+
            '<div class="admin-row"><input class="admin-input" id="admAddCoins" type="number" placeholder="Add coins..."><button class="admin-btn go" id="admAddCoinsBtn">Add</button></div>'+
            '<div class="admin-info">Current: $'+fmt(Math.floor(balance))+'</div></div>'+
            '<div class="admin-section"><div class="admin-section-title"><i class="fas fa-toggle-on" style="margin-right:4px"></i>Toggles</div>'+
            '<div class="admin-row"><button class="admin-btn'+(adminStates.godMode?' active':'')+'" id="admGod">God Mode</button><button class="admin-btn'+(adminStates.infiniteMoney?' active':'')+'" id="admInf">Infinite $</button><button class="admin-btn" id="admSpeed">Speed: '+adminStates.speedMult+'x</button></div></div>'+
            '<div class="admin-section"><div class="admin-section-title"><i class="fas fa-xmark" style="margin-right:4px"></i>Win Multiplier</div>'+
            '<div class="admin-row"><input class="admin-input" id="admWinMult" type="number" placeholder="Multiplier..." step="0.5" min="0"><button class="admin-btn go" id="admWinMultBtn">Set</button></div>'+
            '<div class="admin-info">Current: '+adminStates.winMult+'x</div></div>'+
            '<div class="admin-section"><div class="admin-section-title"><i class="fas fa-crosshairs" style="margin-right:4px"></i>Force Slot</div>'+
            '<div class="admin-slot-row" id="admSlots"></div></div>'+
            '<div class="admin-section"><div class="admin-section-title"><i class="fas fa-bolt" style="margin-right:4px"></i>Quick Actions</div>'+
            '<div class="admin-row"><button class="admin-btn" id="admUnlockAll">Unlock All</button><button class="admin-btn" id="admMaxUpg">Max Upgrades</button><button class="admin-btn" id="admClearBalls">Clear Balls</button></div>'+
            '<div class="admin-row"><button class="admin-btn" id="admBuyEndgame">Buy All Endgame</button><button class="admin-btn" id="admPrestigeMax">Max Prestige</button></div></div>'+
            '<div class="admin-section"><div class="admin-section-title"><i class="fas fa-list" style="margin-right:4px"></i>Codes</div>'+
            '<div style="font-size:.55rem;color:#4a4050;line-height:1.8">'+Object.keys(CODES).filter(function(k){return!CODES[k].nl;}).map(function(k){return'<span style="color:#818cf8;font-weight:700">'+k+'</span>';}).join(' &middot; ')+'<br><span style="color:#c084fc;font-weight:700">'+ADMIN_CODE+'</span></div></div>'+
            '<div class="admin-section"><button class="admin-btn danger full" id="admReset"><i class="fas fa-skull" style="margin-right:6px"></i>FULL RESET</button></div>';
        ov.appendChild(modal);document.body.appendChild(ov);
        document.getElementById('adminClose').addEventListener('click',closeAdminPanel);
        document.getElementById('admSetBalBtn').addEventListener('click',function(){var v=parseInt(document.getElementById('admSetBal').value);if(!isNaN(v)){balance=Math.max(0,v);toast('Balance: $'+fmt(v),true);updateUI();refInfo();}});
        document.getElementById('admAddCoinsBtn').addEventListener('click',function(){var v=parseInt(document.getElementById('admAddCoins').value);if(!isNaN(v)){balance+=v;toast('+'+fmt(v),true);updateUI();refInfo();}});
        document.getElementById('admGod').addEventListener('click',function(){adminStates.godMode=!adminStates.godMode;this.classList.toggle('active',adminStates.godMode);toast('God Mode '+(adminStates.godMode?'ON':'OFF'),'admin');updateUI();});
        document.getElementById('admInf').addEventListener('click',function(){adminStates.infiniteMoney=!adminStates.infiniteMoney;this.classList.toggle('active',adminStates.infiniteMoney);toast('Infinite Money '+(adminStates.infiniteMoney?'ON':'OFF'),'admin');updateUI();});
        document.getElementById('admSpeed').addEventListener('click',function(){var sp=[1,2,3,5,10];adminStates.speedMult=sp[(sp.indexOf(adminStates.speedMult)+1)%sp.length];this.textContent='Speed: '+adminStates.speedMult+'x';});
        document.getElementById('admWinMultBtn').addEventListener('click',function(){var v=parseFloat(document.getElementById('admWinMult').value);if(!isNaN(v)&&v>=0){adminStates.winMult=v;toast('Win mult: '+v+'x','admin');refInfo();}});
        document.getElementById('admUnlockAll').addEventListener('click',function(){var k=Object.keys(SHAPES);for(var i=0;i<k.length;i++)unlockedShapes[k[i]]=true;toast('All unlocked!','admin');updateUI();});
        document.getElementById('admMaxUpg').addEventListener('click',function(){for(var k in upgLevels)upgLevels[k]=4;toast('All upgrades maxed!','admin');updateUI();});
        document.getElementById('admClearBalls').addEventListener('click',function(){balls=[];particles=[];dropping=false;updateUI();});
        document.getElementById('admBuyEndgame').addEventListener('click',function(){for(var k in endgamePurchased)endgamePurchased[k]=true;toast('All endgame!','admin');updateUI();});
        document.getElementById('admPrestigeMax').addEventListener('click',function(){prestigeLevel=10;toast('Prestige Lv.10!','admin');updateUI();});
        document.getElementById('admReset').addEventListener('click',function(){closeAdminPanel();doFullReset();});
        var slotRow=document.getElementById('admSlots');
        for(var i=0;i<7;i++){(function(si){var btn=document.createElement('button');btn.className='admin-slot-btn';btn.textContent=si+'x';btn.addEventListener('click',function(){slotRow.querySelectorAll('.admin-slot-btn').forEach(function(b){b.classList.remove('active');});btn.classList.add('active');adminStates.forceSlot=si;toast('Forced slot '+si,'admin');});slotRow.appendChild(btn);})(i);}
        function refInfo(){var inf=modal.querySelectorAll('.admin-info');if(inf[0])inf[0].textContent='Current: $'+fmt(Math.floor(balance));if(inf[1])inf[1].textContent='Current: '+adminStates.winMult+'x';}
    }
    function closeAdminPanel(){adminOpen=false;var ov=document.getElementById('adminOverlay');if(ov)ov.remove();}

    function doPrestige(){
        if(balance<PRESTIGE_COST&&!adminStates.infiniteMoney)return;
        if(!adminStates.infiniteMoney)balance=START_BAL;
        totalWon=0;bestBal=Math.max(bestBal,START_BAL);prevBal=balance;
        upgLevels={lucky:0,heavy:0,magnet:0,golden:0,fortune:0,precision:0,momentum:0};
        endgamePurchased={autodrop:false,multiball:false,goldenaura:false,cosmicluck:false};
        prestigeLevel++;bet=50;isCustomBet=false;
        chipBtns.forEach(function(c){c.classList.toggle('active',parseInt(c.dataset.b)===50);});
        customInput.value='';
        toast('PRESTIGE Lv.'+prestigeLevel+' — '+getPrestigeMult()+'x mult!','admin');
        updateUI();
    }

    function doFullReset(){
        shape='diamond';buildBoard();balls=[];particles=[];
        balance=START_BAL;totalWon=0;bestBal=START_BAL;prevBal=START_BAL;
        dropping=false;bet=50;isCustomBet=false;
        unlockedShapes={diamond:true,grid:true};
        upgLevels={lucky:0,heavy:0,magnet:0,golden:0,fortune:0,precision:0,momentum:0};
        endgamePurchased={autodrop:false,multiball:false,goldenaura:false,cosmicluck:false};
        prestigeLevel=0;lifelinesUsed=0;autoDropTimer=0;
        adminStates={godMode:false,infiniteMoney:false,speedMult:1,forceSlot:-1,winMult:1};
        codeUses={};
        chipBtns.forEach(function(c){c.classList.toggle('active',parseInt(c.dataset.b)===50);});
        customInput.value='';codeInput.value='';
        document.getElementById('lifelineBadge').style.display='none';
        document.getElementById('adminBadge').style.display='none';
        toast('Full reset','');updateUI();
    }

    function initGame(){
        shape='diamond';buildBoard();balls=[];particles=[];
        balance=START_BAL;totalWon=0;bestBal=START_BAL;prevBal=START_BAL;
        dropping=false;bet=50;isCustomBet=false;
        unlockedShapes={diamond:true,grid:true};
        upgLevels={lucky:0,heavy:0,magnet:0,golden:0,fortune:0,precision:0,momentum:0};
        endgamePurchased={autodrop:false,multiball:false,goldenaura:false,cosmicluck:false};
        prestigeLevel=0;lifelinesUsed=0;autoDropTimer=0;
        adminStates={godMode:false,infiniteMoney:false,speedMult:1,forceSlot:-1,winMult:1};
        codeUses={};
        chipBtns.forEach(function(c){c.classList.toggle('active',parseInt(c.dataset.b)===50);});
        customInput.value='';codeInput.value='';
        document.getElementById('lifelineBadge').style.display='none';
        document.getElementById('adminBadge').style.display='none';
        updateUI();
    }

    /* ===== EVENTS ===== */
    chipBtns.forEach(function(c){c.addEventListener('click',function(){var v=parseInt(c.dataset.b);if(v<=balance||adminStates.infiniteMoney)selectBet(v);});});
    customBtn.addEventListener('click',function(){var v=parseInt(customInput.value);if(!isNaN(v))setCustomBet(v);});
    customInput.addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();var v=parseInt(customInput.value);if(!isNaN(v))setCustomBet(v);}});
    codeInput.addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();handleCode(codeInput.value);}});
    btnDrop.addEventListener('click',dropBall);
    btnReset.addEventListener('click',function(){if(adminOpen)closeAdminPanel();else doFullReset();});
    btnPrestige.addEventListener('click',doPrestige);
    canvas.addEventListener('click',function(e){e.preventDefault();dropBall();});
    document.addEventListener('keydown',function(e){
        if(document.activeElement===customInput||document.activeElement===codeInput)return;
        if(e.code==='Space'||e.code==='Enter'){e.preventDefault();dropBall();}
        if(e.code==='KeyR'&&!e.ctrlKey)doFullReset();
    });

    function loop(){var steps=adminStates.speedMult||1;for(var i=0;i<steps;i++)update();draw();requestAnimationFrame(loop);}
    initGame();loop();
    </script>
</body>
</html>


