<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plinko</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root{--bg:#08080f;--fg:#f5f0e8;--muted:#6b6570;--accent:#10b981;--card:#0f0f18;--border:#1c1c2a}
        *{margin:0;padding:0;box-sizing:border-box}
        body{background:var(--bg);color:var(--fg);font-family:'Outfit',sans-serif;min-height:100vh;display:flex;justify-content:center;align-items:flex-start;overflow-x:hidden;padding-top:10px}
        .bg-blob{position:fixed;border-radius:50%;filter:blur(100px);opacity:.12;pointer-events:none;animation:bd 25s ease-in-out infinite alternate}
        @keyframes bd{0%{transform:translate(0,0) scale(1)}50%{transform:translate(40px,-40px) scale(1.15)}100%{transform:translate(-30px,30px) scale(.9)}}
        .app{position:relative;z-index:1;display:flex;gap:14px;max-width:780px;width:100%;padding:10px;align-items:flex-start}
        .side{width:240px;display:flex;flex-direction:column;gap:10px;flex-shrink:0;max-height:calc(100vh - 20px);overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
        .side::-webkit-scrollbar{width:4px}.side::-webkit-scrollbar-track{background:transparent}.side::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
        .board-col{flex:1;display:flex;flex-direction:column;gap:10px;min-width:0}
        .title{font-size:2rem;font-weight:900;letter-spacing:8px;text-align:center;background:linear-gradient(135deg,var(--accent),#fbbf24,var(--accent));background-size:200% 200%;animation:sh 4s ease-in-out infinite;-webkit-background-clip:text;-webkit-text-fill-color:transparent}
        @keyframes sh{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
        .pnl{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:12px}
        .pnl-t{font-size:.6rem;color:var(--muted);text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;font-weight:700}
        .stat-row{display:flex;gap:6px;width:100%;flex-wrap:wrap}
        .stat-box{flex:1;min-width:70px;padding:7px 4px;background:var(--card);border:1px solid var(--border);border-radius:8px;text-align:center}
        .stat-l{font-size:.5rem;color:var(--muted);text-transform:uppercase;letter-spacing:1.2px;margin-bottom:1px}
        .stat-v{font-size:1rem;font-weight:900;color:var(--accent);transition:transform .15s}
        .stat-v.bump{transform:scale(1.2)}
        .stat-v.prestige-glow{color:#f472b6;text-shadow:0 0 8px rgba(244,114,182,.5)}
        .shape-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
        .shape-btn{padding:7px 3px;border:2px solid var(--border);border-radius:8px;background:transparent;color:var(--muted);font-family:'Outfit',sans-serif;font-weight:700;font-size:.58rem;cursor:pointer;transition:all .2s;text-align:center;line-height:1.2}
        .shape-btn:hover:not(.locked){border-color:var(--accent);color:var(--fg)}
        .shape-btn.active{border-color:var(--accent);color:var(--accent);background:rgba(16,185,129,.08);box-shadow:0 0 16px rgba(16,185,129,.1)}
        .shape-btn.locked{opacity:.35;cursor:default}
        .shape-btn.prest{border-color:rgba(244,114,182,.2)}
        .shape-btn.prest:hover:not(.locked){border-color:rgba(244,114,182,.5)}
        .shape-btn.prest.active{border-color:#f472b6;color:#f472b6;background:rgba(244,114,182,.08);box-shadow:0 0 16px rgba(244,114,182,.15)}
        .shape-btn .si{display:block;font-size:.85rem;margin-bottom:1px}
        .shape-btn .sc{display:block;font-size:.44rem;color:var(--muted);margin-top:1px}
        .shape-btn .sr{display:block;font-size:.38rem;color:#f472b6;margin-top:1px;font-weight:600}
        .chip-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px}
        .chip{padding:7px 4px;border:2px solid var(--border);border-radius:7px;background:transparent;color:var(--muted);font-family:'Outfit',sans-serif;font-weight:700;font-size:.7rem;cursor:pointer;transition:all .2s;text-align:center}
        .chip:hover{border-color:var(--accent);color:var(--fg)}
        .chip.active{border-color:var(--accent);color:var(--accent);background:rgba(16,185,129,.08)}
        .chip.dis{opacity:.2;pointer-events:none}
        .custom-bet{display:flex;gap:5px;margin-top:6px}
        .custom-bet input{flex:1;padding:7px 8px;border:2px solid var(--border);border-radius:7px;background:transparent;color:var(--fg);font-family:'Outfit',sans-serif;font-size:.72rem;font-weight:700;outline:none;transition:border-color .2s,box-shadow .2s;min-width:0}
        .custom-bet input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(16,185,129,.15)}
        .custom-bet input::placeholder{color:var(--muted);font-weight:400}
        .custom-bet button{padding:7px 12px;border:2px solid var(--accent);border-radius:7px;background:rgba(16,185,129,.08);color:var(--accent);font-family:'Outfit',sans-serif;font-weight:700;font-size:.65rem;cursor:pointer;transition:all .2s;white-space:nowrap}
        .custom-bet button:hover{background:rgba(16,185,129,.18)}
        .shop-item{display:flex;align-items:center;gap:8px;padding:8px;border:1px solid var(--border);border-radius:8px;margin-bottom:6px;transition:all .2s}
        .shop-item:hover{border-color:rgba(16,185,129,.3)}
        .shop-item.endgame{border-color:rgba(168,85,247,.15)}
        .shop-item.endgame:hover{border-color:rgba(168,85,247,.4)}
        .shop-icon{width:30px;height:30px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:.8rem;flex-shrink:0}
        .shop-info{flex:1;min-width:0}
        .shop-name{font-size:.68rem;font-weight:700;color:var(--fg)}
        .shop-desc{font-size:.52rem;color:var(--muted);line-height:1.2}
        .shop-buy{padding:4px 9px;border:1px solid var(--accent);border-radius:5px;background:transparent;color:var(--accent);font-family:'Outfit',sans-serif;font-weight:700;font-size:.58rem;cursor:pointer;transition:all .2s;white-space:nowrap;flex-shrink:0}
        .shop-buy:hover{background:rgba(16,185,129,.1)}
        .shop-buy:disabled{opacity:.25;cursor:not-allowed}
        .shop-buy.owned{border-color:var(--border);color:var(--muted);cursor:default}
        .shop-buy.endgame-buy{border-color:#a855f7;color:#a855f7}
        .shop-buy.endgame-buy:hover{background:rgba(168,85,247,.1)}
        .shop-buy.endgame-buy.owned{border-color:var(--border);color:var(--muted)}
        .lvl-dots{display:flex;gap:2px;margin-top:3px}
        .lvl-dot{width:6px;height:6px;border-radius:50%;background:var(--border);transition:background .3s}
        .lvl-dot.filled{background:var(--accent)}
        .canvas-wrap{position:relative;border-radius:12px;overflow:hidden;border:1px solid var(--border);background:var(--card);box-shadow:0 0 60px rgba(0,0,0,.5)}
        canvas{display:block;width:100%;height:auto;touch-action:manipulation}
        .btn-row{display:flex;gap:8px;width:100%}
        .gbtn{flex:1;padding:12px;border:none;border-radius:9px;font-family:'Outfit',sans-serif;font-weight:700;font-size:.85rem;cursor:pointer;transition:all .2s;text-transform:uppercase;letter-spacing:2px}
        .gbtn-drop{background:linear-gradient(135deg,var(--accent),#d97706);color:#000;box-shadow:0 4px 24px rgba(16,185,129,.25)}
        .gbtn-drop:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 32px rgba(16,185,129,.35)}
        .gbtn-drop:disabled{opacity:.3;cursor:not-allowed;transform:none;box-shadow:none}
        .gbtn-reset{background:var(--card);color:var(--fg);border:1px solid var(--border)}
        .gbtn-reset:hover{border-color:var(--accent)}
        .gbtn-prestige{background:linear-gradient(135deg,#f472b6,#a855f7);color:#fff;box-shadow:0 4px 20px rgba(244,114,182,.2);display:none}
        .gbtn-prestige:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 28px rgba(244,114,182,.35)}
        .gbtn-prestige:disabled{opacity:.3;cursor:not-allowed;transform:none}
        .auto-indicator{display:none;align-items:center;gap:4px;font-size:.55rem;color:#22d3ee;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:0 8px}
        .auto-indicator.on{display:flex}
        .auto-indicator .dot{width:5px;height:5px;border-radius:50%;background:#22d3ee;animation:bpulse 1s ease-in-out infinite}
        @keyframes bpulse{0%,100%{opacity:1}50%{opacity:.3}}
        .score-pop{position:absolute;pointer-events:none;font-weight:900;font-size:1.2rem;animation:fu 1s ease-out forwards;text-shadow:0 0 10px currentColor;white-space:nowrap}
        @keyframes fu{0%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-55px) scale(1.5)}}
        .score-pop.neg{color:#ef4444!important;animation:fd 1s ease-out forwards}
        @keyframes fd{0%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(30px) scale(1.3)}}
        .toast{position:fixed;top:20px;left:50%;transform:translateX(-50%) translateY(-80px);padding:10px 20px;border-radius:8px;font-family:'Outfit',sans-serif;font-weight:700;font-size:.8rem;z-index:100;transition:transform .4s cubic-bezier(.4,0,.2,1);pointer-events:none}
        .toast.show{transform:translateX(-50%) translateY(0)}
        .toast.ok{background:rgba(16,185,129,.9);color:#000}
        .toast.err{background:rgba(239,68,68,.9);color:#fff}
        .toast.admin{background:rgba(168,85,247,.9);color:#fff}
        .lifeline-badge{position:absolute;top:8px;right:8px;background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:#ef4444;font-size:.55rem;font-weight:700;padding:3px 8px;border-radius:4px;pointer-events:none;z-index:2;letter-spacing:1px;text-transform:uppercase}
        .admin-badge{position:absolute;top:8px;left:8px;background:rgba(168,85,247,.15);border:1px solid rgba(168,85,247,.3);color:#a855f7;font-size:.5rem;font-weight:700;padding:3px 8px;border-radius:4px;pointer-events:none;z-index:2;letter-spacing:1px;text-transform:uppercase;display:none}
        .code-panel{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 12px;opacity:.5;transition:opacity .3s}
        .code-panel:focus-within{opacity:1;border-color:rgba(168,85,247,.3)}
        .code-panel input{width:100%;padding:6px 8px;border:1px solid var(--border);border-radius:6px;background:transparent;color:var(--fg);font-family:'Outfit',sans-serif;font-size:.65rem;font-weight:600;outline:none;transition:border-color .2s}
        .code-panel input:focus{border-color:#a855f7}
        .code-panel input::placeholder{color:var(--muted);font-weight:400}
        .admin-overlay{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:300;display:flex;align-items:center;justify-content:center;animation:afadein .3s}
        @keyframes afadein{from{opacity:0}to{opacity:1}}
        .admin-modal{background:#0c0c16;border:1px solid #2a1f3d;border-radius:16px;padding:24px;width:460px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 0 80px rgba(168,85,247,.15)}
        .admin-modal::-webkit-scrollbar{width:4px}.admin-modal::-webkit-scrollbar-track{background:transparent}.admin-modal::-webkit-scrollbar-thumb{background:#2a1f3d;border-radius:2px}
        .admin-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
        .admin-title{font-size:1.1rem;font-weight:900;color:#a855f7;letter-spacing:3px}
        .admin-close{width:32px;height:32px;border:1px solid #2a1f3d;border-radius:8px;background:transparent;color:#6b6570;font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
        .admin-close:hover{border-color:#a855f7;color:#a855f7}
        .admin-section{margin-bottom:18px}
        .admin-section-title{font-size:.6rem;color:#6b6570;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;font-weight:700}
        .admin-row{display:flex;gap:8px;margin-bottom:8px;flex-wrap:wrap}
        .admin-input{flex:1;min-width:80px;padding:8px 10px;border:1px solid #2a1f3d;border-radius:8px;background:transparent;color:var(--fg);font-family:'Outfit',sans-serif;font-size:.75rem;font-weight:600;outline:none;transition:border-color .2s}
        .admin-input:focus{border-color:#a855f7}
        .admin-input::placeholder{color:#4a4050}
        .admin-btn{padding:8px 14px;border:1px solid #2a1f3d;border-radius:8px;background:transparent;color:#a855f7;font-family:'Outfit',sans-serif;font-weight:700;font-size:.7rem;cursor:pointer;transition:all .2s;white-space:nowrap}
        .admin-btn:hover{background:rgba(168,85,247,.1);border-color:#a855f7}
        .admin-btn.active{background:rgba(168,85,247,.15);border-color:#a855f7;color:#c084fc;box-shadow:0 0 12px rgba(168,85,247,.15)}
        .admin-btn.danger{border-color:rgba(239,68,68,.3);color:#ef4444}
        .admin-btn.danger:hover{background:rgba(239,68,68,.1);border-color:#ef4444}
        .admin-btn.go{border-color:rgba(16,185,129,.3);color:#10b981}
        .admin-btn.go:hover{background:rgba(16,185,129,.1);border-color:#10b981}
        .admin-btn.full{width:100%}
        .admin-info{font-size:.6rem;color:#4a4050;margin-top:2px}
        .admin-slot-row{display:flex;gap:4px}
        .admin-slot-btn{flex:1;padding:6px 2px;border:1px solid #2a1f3d;border-radius:6px;background:transparent;color:#6b6570;font-family:'Outfit',sans-serif;font-weight:700;font-size:.65rem;cursor:pointer;transition:all .2s;text-align:center}
        .admin-slot-btn:hover{border-color:#a855f7;color:#a855f7}
        .admin-slot-btn.active{background:rgba(168,85,247,.15);border-color:#a855f7;color:#c084fc}
        @media(max-width:700px){
            .app{flex-direction:column;align-items:center}
            .side{width:100%;max-width:480px;max-height:none;overflow-y:visible}
            .shape-grid{grid-template-columns:repeat(4,1fr)}
            .chip-grid{grid-template-columns:repeat(4,1fr)}
            .title{font-size:1.5rem;letter-spacing:5px}
            .admin-modal{padding:16px}
        }
    </style>
</head>
<body>
    <div class="bg-blob" style="width:450px;height:450px;background:#f59e0b;top:-150px;left:-100px"></div>
    <div class="bg-blob" style="width:350px;height:350px;background:#ef4444;bottom:-100px;right:-80px;animation-delay:-9s"></div>
    <div class="bg-blob" style="width:280px;height:280px;background:#10b981;top:40%;left:55%;animation-delay:-16s"></div>
    <div class="app">
        <aside class="side">
            <h1 class="title">PLINKO</h1>
            <div class="pnl">
                <div class="pnl-t">Board Shape</div>
                <div class="shape-grid" id="shapeGrid"></div>
            </div>
            <div class="pnl">
                <div class="pnl-t">Bet Amount</div>
                <div class="chip-grid" id="chipRow">
                    <button class="chip" data-b="5">5</button>
                    <button class="chip" data-b="10">10</button>
                    <button class="chip" data-b="25">25</button>
                    <button class="chip active" data-b="50">50</button>
                    <button class="chip" data-b="100">100</button>
                    <button class="chip" data-b="250">250</button>
                    <button class="chip" data-b="500">500</button>
                    <button class="chip" data-b="1000">1K</button>
                    <button class="chip" data-b="2500">2.5K</button>
                </div>
                <div class="custom-bet">
                    <input type="number" id="customBetInput" placeholder="Custom bet..." min="1" step="1">
                    <button id="customBetBtn">SET</button>
                </div>
            </div>
            <div class="pnl">
                <div class="pnl-t">Upgrades</div>
                <div id="upgShop"></div>
            </div>
            <div class="pnl" id="endgamePanel" style="display:none">
                <div class="pnl-t"><i class="fas fa-crown" style="margin-right:4px;color:#a855f7"></i>Endgame</div>
                <div id="endgameShop"></div>
            </div>
            <div class="code-panel">
                <div style="font-size:.5rem;color:var(--muted);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:5px;font-weight:700"><i class="fas fa-lock" style="margin-right:3px"></i>Code Entry</div>
                <input type="text" id="codeInput" placeholder="Enter code..." autocomplete="off" spellcheck="false">
            </div>
        </aside>
        <div class="board-col">
            <div class="stat-row">
                <div class="stat-box"><div class="stat-l">Balance</div><div class="stat-v" id="sBal">1,000</div></div>
                <div class="stat-box"><div class="stat-l">Total Won</div><div class="stat-v" id="sWon">0</div></div>
                <div class="stat-box"><div class="stat-l">Best Bal</div><div class="stat-v" id="sBest">1,000</div></div>
                <div class="stat-box"><div class="stat-l">Prestige</div><div class="stat-v" id="sPrest">0</div></div>
            </div>
            <div class="canvas-wrap" id="canvasWrap">
                <canvas id="c"></canvas>
                <div class="admin-badge" id="adminBadge"><i class="fas fa-shield-halved" style="margin-right:3px"></i>Admin</div>
                <div class="lifeline-badge" id="lifelineBadge" style="display:none"><i class="fas fa-heart" style="margin-right:3px"></i> Lifeline</div>
            </div>
            <div class="btn-row">
                <button class="gbtn gbtn-drop" id="btnDrop"><i class="fas fa-arrow-down" style="margin-right:6px"></i>Drop</button>
                <button class="gbtn gbtn-reset" id="btnReset"><i class="fas fa-rotate-right" style="margin-right:6px"></i>Reset</button>
            </div>
            <div class="btn-row">
                <div class="auto-indicator" id="autoInd"><div class="dot"></div>Auto</div>
                <button class="gbtn gbtn-prestige" id="btnPrestige"><i class="fas fa-star" style="margin-right:6px"></i>Prestige</button>
            </div>
        </div>
    </div>
    <div class="toast" id="toast"></div>

    <script>
    var CW=480,CH=660,BL=28,BR=CW-28,BT=55,BB=CH-65,BWALL=4;
    var START_BAL=1000,LIFELINE_AMT=100,PEG_R=5,BALL_R=8,SLOT_ZONE=12,PRESTIGE_COST=10000;
    var canvas=document.getElementById('c'),ctx=canvas.getContext('2d');
    canvas.width=CW;canvas.height=CH;

    function hr(h,a){return'rgba('+parseInt(h.slice(1,3),16)+','+parseInt(h.slice(3,5),16)+','+parseInt(h.slice(5,7),16)+','+a+')';}
    function lerp(a,b,t){return a+(b-a)*t;}
    function clamp(v,l,h){return Math.max(l,Math.min(h,v));}
    function fmt(n){if(n>=1e9)return(n/1e9).toFixed(1)+'B';if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1e4)return(n/1e3).toFixed(1)+'K';return Math.floor(n).toLocaleString('en-US');}

    /* ===== PEG GEN ===== */
    function hSpace(){return(BR-BL)/cfg.slots;}
    function genPegRows(n,off){
        var p=[],hs=hSpace(),rh=(BB-BT-SLOT_ZONE)/n,wL=BL+BWALL+PEG_R+6,wR=BR-BWALL-PEG_R-6;
        for(var r=0;r<n;r++){var y=BT+(r+.5)*rh,o=off?off(r):0,cnt,base;
            if(r%2===0){cnt=7;base=.5}else{cnt=6;base=1}
            for(var c=0;c<cnt;c++){var x=BL+(c+base)*hs+o;if(x>=wL&&x<=wR)p.push({x:x,y:y,glow:0});}
        }return p;
    }

    /* ===== PEG STYLES ===== */
    function drawCirclePeg(x,y,r,a,g){
        if(g>.05){var gr=ctx.createRadialGradient(x,y,0,x,y,r+14*g);gr.addColorStop(0,hr(a,g*.65));gr.addColorStop(1,hr(a,0));ctx.fillStyle=gr;ctx.beginPath();ctx.arc(x,y,r+14*g,0,Math.PI*2);ctx.fill();}
        ctx.fillStyle=hr('#c4b5a0',lerp(.25,1,g));ctx.beginPath();ctx.arc(x,y,Math.max(.5,r),0,Math.PI*2);ctx.fill();
        ctx.fillStyle='rgba(255,255,255,'+(0.12+g*.3)+')';ctx.beginPath();ctx.arc(x-r*.3,y-r*.3,Math.max(.3,r*.35),0,Math.PI*2);ctx.fill();
    }
    function drawHexPeg(x,y,r,a,g){
        var rd=Math.max(1,r*1.15);
        if(g>.05){var gr=ctx.createRadialGradient(x,y,0,x,y,rd+14*g);gr.addColorStop(0,hr(a,g*.7));gr.addColorStop(1,hr(a,0));ctx.fillStyle=gr;ctx.beginPath();ctx.arc(x,y,rd+14*g,0,Math.PI*2);ctx.fill();}
        ctx.fillStyle=hr(a,lerp(.25,1,g));ctx.beginPath();for(var i=0;i<6;i++){var an=Math.PI/3*i-Math.PI/6;if(i===0)ctx.moveTo(x+rd*Math.cos(an),y+rd*Math.sin(an));else ctx.lineTo(x+rd*Math.cos(an),y+rd*Math.sin(an));}ctx.closePath();ctx.fill();
    }
    function drawNeonPeg(x,y,r,a,g){
        var rd=Math.max(.5,r*.75);
        ctx.strokeStyle=hr(a,.12+g*.5);ctx.lineWidth=1;ctx.beginPath();ctx.arc(x,y,rd+6+g*8,0,Math.PI*2);ctx.stroke();
        ctx.strokeStyle=hr(a,.06+g*.25);ctx.beginPath();ctx.arc(x,y,rd+12+g*12,0,Math.PI*2);ctx.stroke();
        var cg=ctx.createRadialGradient(x,y,0,x,y,rd+2);cg.addColorStop(0,hr('#ffffff',.9+g*.1));cg.addColorStop(.5,hr(a,.7+g*.3));cg.addColorStop(1,hr(a,0));
        ctx.fillStyle=cg;ctx.beginPath();ctx.arc(x,y,rd+2,0,Math.PI*2);ctx.fill();
