            if(!canSeeShape(key))return;
            var ul=unlockedShapes[key],ia=(key===shape);
            var btn=document.createElement('button');
            var cls='shape-btn'+(ia?' active':'')+(!ul?' locked':'');
            if(s.cat==='prest')cls+=' prest';
            btn.className=cls;
            var ch=(!ul&&s.cost>0)?'<span class="sc">$'+fmt(s.cost)+'</span>':'';
            var req=(!ul&&s.preq)?'<span class="sr"><i class="fas fa-star" style="font-size:.32rem;margin-right:1px"></i>P'+s.preq+'</span>':'';
            btn.innerHTML='<i class="fas '+s.icon+' si" style="color:'+s.color+'"></i>'+s.name+ch+req;
            btn.addEventListener('click',function(){
                if(ul){if(key!==shape){shape=key;buildBoard();balls=[];particles=[];dropping=false;updateUI();}}
                else{if(balance>=s.cost||adminStates.infiniteMoney){if(!adminStates.infiniteMoney)balance-=s.cost;unlockedShapes[key]=true;shape=key;buildBoard();balls=[];particles=[];dropping=false;toast(s.name+' unlocked!',true);updateUI();}
