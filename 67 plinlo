        }
        balls=balls.filter(function(b){return b.alive;});
        if(balls.length===0&&dropping)dropping=false;
        for(var i=0;i<particles.length;i++){var pt=particles[i];pt.x+=pt.vx;pt.y+=pt.vy;pt.vy+=.06;pt.life-=pt.dec;}
        particles=particles.filter(function(pt){return pt.life>0;});
        for(var i=0;i<pegs.length;i++){if(pegs[i].glow>0)pegs[i].glow=Math.max(0,pegs[i].glow-.035);}
        if(balance<=0&&balls.length===0&&!adminStates.infiniteMoney)grantLifeline();
    }

