            if(b.y<BT+BWALL+BALL_R&&b.vy<0){b.y=BT+BWALL+BALL_R;b.vy=Math.abs(b.vy)*damp;}

            if(b.y<slotTop){
                for(var pi=0;pi<pegs.length;pi++){var p=pegs[pi],dx=b.x-p.x,dy=b.y-p.y,dSq=dx*dx+dy*dy,minD=b.r+PEG_R;
                    if(dSq<minD*minD){var d=Math.sqrt(Math.max(dSq,.001)),nx=dx/d,ny=dy/d;b.x=p.x+nx*(minD+.5);b.y=p.y+ny*(minD+.5);var dot=b.vx*nx+b.vy*ny;if(dot<0){b.vx-=2*dot*nx;b.vy-=2*dot*ny;}b.vx*=damp;b.vy*=damp;b.vx+=(Math.random()-.5)*rand;if(b.vy<-.3)b.vy=-.3;p.glow=1;emit(p.x,p.y,2);}}
            }else{
                for(var di=0;di<dividers.length;di++){var dvx=dividers[di],half=b.r+.5,crossed=(prevX<=dvx&&b.x>dvx)||(prevX>=dvx&&b.x<dvx),overlapping=Math.abs(b.x-dvx)<half;
                    if(crossed||overlapping){if(b.x<=dvx){b.x=dvx-half;b.vx=-Math.abs(b.vx)*.05;}else{b.x=dvx+half;b.vx=Math.abs(b.vx)*.05;}}}
                if(b.vy<1.5)b.vy=1.5;b.vx*=.85;
            }

            if(b.y>=BB+25&&!b.scored){
                b.scored=true;b.vx=0;b.vy=0;b.trail=[];
                var idx=-1;
                for(var si=0;si<slots.length;si++){if(b.x>=slots[si].l&&b.x<=slots[si].r){idx=si;break;}}
                if(idx<0){var bd=Infinity;for(var si=0;si<slots.length;si++){var dd=Math.abs(b.x-slots[si].cx);if(dd<bd){bd=dd;idx=si;}}}
                if(adminStates.godMode){var best=0;for(var si=0;si<slots.length;si++)if(slots[si].val>slots[best].val)best=si;idx=best;}
                if(adminStates.forceSlot>=0&&adminStates.forceSlot<slots.length){idx=adminStates.forceSlot;adminStates.forceSlot=-1;}
                if(idx>=0){
                    var mult=slots[idx].val;
                    var auraMult=(endgamePurchased.goldenaura?1.1:1)*(endgamePurchased.cosmicluck?1.25:1);
                    var win=Math.round(b.betAmt*mult*goldMult*auraMult*getPrestigeMult()*adminStates.winMult);
                    balance+=win;
