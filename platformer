            ctx.lineTo(x + B - 10 + shakeOff, y);
            ctx.lineTo(x + B/2 + shakeOff, y + icicleHeight * 0.7);
            ctx.closePath();
            ctx.fill();
            // Warning indicator
            if(phase === 1) {
                ctx.fillStyle = 'rgba(255, 82, 82, 0.4)';
                ctx.fillRect(x, y, B, B);
            }
            ctx.strokeStyle = '#4FC3F7'; ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(x + 6 + shakeOff, y);
            ctx.lineTo(x + B/2 + shakeOff, y + icicleHeight);
            ctx.lineTo(x + B - 6 + shakeOff, y);
            ctx.stroke();
        }
        else if(b.type === 'portal') {
            ctx.fillStyle = '#9C27B0'; ctx.fillRect(x, y, B, B*3);
            ctx.fillStyle = '#E1BEE7'; ctx.fillRect(x+6, y+6, B-12, B-12); ctx.fillRect(x+6, y+B+6, B-12, B-12); ctx.fillRect(x+6, y+B+B+6, B-12, B-12);
        }
    }

    function drawEntity(entity, color) {
        let x = entity.x; let y = entity.y;
        ctx.save(); ctx.translate(x + entity.w/2, y + entity.h); ctx.scale(entity.scaleX, entity.scaleY);
        ctx.fillStyle = color; ctx.fillRect(-entity.w/2, -entity.h, entity.w, entity.h);
        ctx.fillStyle = '#FFF'; ctx.fillRect(-7, -entity.h+6, 5, 5); ctx.fillRect(2, -entity.h+6, 5, 5);
        ctx.fillStyle = '#000'; ctx.fillRect(-6, -entity.h+8, 2, 2); ctx.fillRect(3, -entity.h+8, 2, 2);
        ctx.restore();
    }

    // Draw a lightning bolt from sky to target Y
    function drawLightningBolt(targetX, targetY, seed) {
        const boltX = targetX + B/2;
        ctx.save();
        // Outer glow
        ctx.strokeStyle = 'rgba(255, 235, 59, 0.35)';
        ctx.lineWidth = 10;
        ctx.beginPath();
        ctx.moveTo(boltX, 0);
        let cy = 0;
        let rng = seed;
        while(cy < targetY) {
            rng = (rng * 1103515245 + 12345) & 0x7fffffff;
            let off = ((rng % 80) - 40);
            cy += 12 + (rng % 20);
            ctx.lineTo(boltX + off, Math.min(cy, targetY));
        }
        ctx.stroke();
        // Core bolt
        ctx.strokeStyle = '#FFF';
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.moveTo(boltX, 0);
        cy = 0; rng = seed;
        while(cy < targetY) {
            rng = (rng * 1103515245 + 12345) & 0x7fffffff;
            let off = ((rng % 72) - 36);
            cy += 12 + (rng % 20);
            ctx.lineTo(boltX + off, Math.min(cy, targetY));
        }
        ctx.stroke();
        // Bright center
        ctx.strokeStyle = '#FFEB3B';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(boltX, 0);
        cy = 0; rng = seed;
        while(cy < targetY) {
            rng = (rng * 1103515245 + 12345) & 0x7fffffff;
            let off = ((rng % 60) - 30);
            cy += 12 + (rng % 20);
            ctx.lineTo(boltX + off, Math.min(cy, targetY));
        }
        ctx.stroke();
        ctx.restore();
    }

    function loop() {
        ctx.clearRect(0, 0, GAME_W, GAME_H);

        // --- FAKE GRASS CRUMBLE LOGIC ---
        if(state === 'PLAYING') {
            for(let b of levelBlocks) {
                if(b.type === 'fake_ice') {
                    // Check if player is standing on this block
                    let playerOnTop = (player.grounded && player.standingOn === 'fake_ice' &&
                                       player.x + player.w > b.x && player.x < b.x + b.w &&
                                       player.y + player.h >= b.y - 2 && player.y + player.h <= b.y + 4);
                    if(playerOnTop) {
                        b.timer++;
                        if(b.timer === CRUMBLE_SHAKE_START + 1) {
                            spawnParticles(b.x + B/2, b.y + B/2, '#4DB6AC', 4);
                        }
                        if(b.timer > CRUMBLE_FALL_START) {
                            b.type = 'air';
                            spawnParticles(b.x + B/2, b.y + B/2, '#4DB6AC', 8);
                            spawnParticles(b.x + B/2, b.y + B/2, '#81D4FA', 4);
                        }
                    }
                }
                if(b.type === 'fake_grass') {
                    // Check if player is standing on this block
                    let playerOnTop = (player.grounded && player.standingOn === 'fake_grass' &&
                                       player.x + player.w > b.x && player.x < b.x + b.w &&
                                       player.y + player.h >= b.y - 2 && player.y + player.h <= b.y + 4);
                    if(playerOnTop) {
                        b.timer++;
                        if(b.timer === CRUMBLE_SHAKE_START + 1) {
                            // Start shaking - spawn dust particles
                            spawnParticles(b.x + B/2, b.y + B/2, '#8B5A2B', 4);
                        }
                        if(b.timer > CRUMBLE_FALL_START) {
                            // Crumble! Block disappears
                            b.type = 'air';
                            spawnParticles(b.x + B/2, b.y + B/2, '#8B5A2B', 8);
                            spawnParticles(b.x + B/2, b.y + B/2, '#4CAF50', 4);
                        }
                    }
                }
            }
        }

        // --- QUICKSAND SINKING (apply once per frame, not per-block!) ---
        if(state === 'PLAYING' && player.grounded && player.standingOn === 'quicksand') {
            let onQuicksand = null;
            for(let b of levelBlocks) {
                if(b.type === 'quicksand' && player.x + player.w > b.x && player.x < b.x + b.w) {
                    onQuicksand = b; break;
                }
            }
            if(onQuicksand) {
                if(!onQuicksand.sinkTimer) onQuicksand.sinkTimer = 0;
                onQuicksand.sinkTimer++;
                // Visual sink: nudge player down slightly (collision resolves, so player stays on top but appears to sink)
                // Speed is already reduced in updateEntity (vx *= 0.35)
                if(onQuicksand.sinkTimer > QUICKSAND_DEATH_TIMER) {
                    if(player.alive) { player.alive = false; spawnParticles(player.x + player.w/2, player.y + player.h/2, '#8B6914', 10); setTimeout(() => { if(!player.alive) respawn(player); }, 500); }
                }
            }
        }
        // Reset sink timer for quicksand blocks player is NOT on
        if(state === 'PLAYING') {
            for(let b of levelBlocks) {
                if(b.type === 'quicksand' && b.sinkTimer > 0) {
                    let playerOn = (player.x + player.w > b.x && player.x < b.x + b.w &&
                                   Math.abs((player.y + player.h) - b.y) < 6);
                    if(!playerOn) b.sinkTimer = 0;
                }
            }
        }

        // --- HANGING VINE UPDATE (moving platform — player stands on top!) ---
        if(state === 'PLAYING') {
            for(let b of levelBlocks) {
                if(b.type === 'hanging_vine') {
                    let prevX = b.x;
                    b.swingTimer += b.swingSpeed / 60;
                    b.x = b.swingCenter + Math.sin(b.swingTimer) * b.swingRange;
                    let deltaX = b.x - prevX;
                    // If player is standing ON TOP of this hanging vine, move them with it
                    // Check: player's feet are at the top of the vine block and player overlaps horizontally
                    if(player.grounded && player.standingOn === 'hanging_vine' &&
                       player.x + player.w > b.x - 2 && player.x < b.x + b.w + 2 &&
                       Math.abs((player.y + player.h) - b.y) < 6) {
                        player.x += deltaX;
                        // Keep player in bounds
                        if(player.x < 0) player.x = 0;
                        if(player.x + player.w > GAME_W) player.x = GAME_W - player.w;
                    }
                }
            }
        }

        // --- ICICLE SYSTEM (Ice Mountains) ---
        if(state === 'PLAYING' && isIceLevel(currentLevel)) {
            // Update icicle blocks — they periodically drop icicle projectiles
            for(let b of levelBlocks) {
                if(b.type === 'icicle') {
                    if(!b.icicleTimer) b.icicleTimer = Math.floor(Math.random() * 180); // Stagger initial timing
                    b.icicleTimer++;
                    // Phase: grow (0-90), shake warning (90-120), drop (120-135), regrow (135-180)
                    if(b.icicleTimer > 180) b.icicleTimer = 0; // Reset cycle
                }
            }
            // Drop icicle projectiles at the right time
            for(let b of levelBlocks) {
                if(b.type === 'icicle' && b.icicleTimer === 120) {
                    icicleProjectiles.push({x: b.x, y: b.y + B, w: B, h: B, vy: 6, life: 120});
                }
            }
            // Update icicle projectiles
            for(let p of icicleProjectiles) {
                p.y += p.vy;
                p.vy += 0.3; // Accelerate
                p.life--;
                // Kill player if hit
                if(player.alive && player.x + player.w > p.x + 4 && player.x < p.x + p.w - 4 &&
                   player.y + player.h > p.y + 4 && player.y < p.y + p.h - 4) {
                    player.alive = false;
                    spawnParticles(player.x + player.w/2, player.y + player.h/2, '#81D4FA', 12);
                    setTimeout(() => { if(!player.alive) respawn(player); }, 500);
                }
                // Remove if off screen or expired
                if(p.y > GAME_H || p.life <= 0) p.dead = true;
            }
            icicleProjectiles = icicleProjectiles.filter(p => !p.dead);
        }

        // --- LIGHTNING STRIKE SYSTEM ---
        if(state === 'PLAYING' && isStormLevel(currentLevel)) {
            lightningCooldown -= 1/60;
            if(lightningCooldown <= 0) {
                let strikeCol;
                if(currentLevel === 7) {
                    // Level 7: Strike near the player, NO warning
                    let playerCol = Math.floor((player.x + player.w/2) / B);
                    let offset = Math.floor(Math.random() * 5) - 2; // -2 to +2
                    strikeCol = Math.max(0, Math.min(24, playerCol + offset));
                    lightningCooldown = 2 + Math.random() * 3; // 2-5 seconds between strikes
                } else {
                    // Levels 5, 10: Random column, NO warning
                    strikeCol = Math.floor(Math.random() * 25);
                    lightningCooldown = 3 + Math.random() * 4; // 3-7 seconds between strikes
                }
                // ALL levels: instant strike, no warning!
                lightningStrikes.push({
                    x: strikeCol * B,
                    phase: 'strike',
                    timer: 0,
                    seed: Math.floor(Math.random() * 100000)
                });
            }

            // Update existing strikes
            for(let strike of lightningStrikes) {
                strike.timer += 1/60;
                if(strike.phase === 'strike' && strike.timer > 0.25) {
                    strike.phase = 'flash';
                    strike.timer = 0;
                }
                if(strike.phase === 'flash' && strike.timer > 0.3) {
                    strike.phase = 'done';
                }
                // Kill player if in strike zone during strike phase
                if(strike.phase === 'strike' && player.alive) {
                    if(player.x + player.w > strike.x + 4 && player.x < strike.x + B - 4) {
                        player.alive = false;
                        spawnParticles(player.x + player.w/2, player.y + player.h/2, '#FFEB3B', 12);
                        setTimeout(() => { if(!player.alive) respawn(player); }, 500);
                    }
                }
            }
            lightningStrikes = lightningStrikes.filter(s => s.phase !== 'done');
        }

        // Spike Timers
        for(let b of levelBlocks) {
            if(b.type === 'spike_up') {
                b.timer--;
                if(b.timer <= 0) b.type = 'spike';
            }
        }

        // --- SKY COLOR & WEATHER ---
        let isStorm = isStormLevel(currentLevel);
        let isJungle = isJungleLevel(currentLevel);
        if(state === 'PLAYING' && isStorm) {
            ctx.fillStyle = '#4A4A4A';
            ctx.fillRect(0, 0, GAME_W, GAME_H);
            // Rain
            ctx.fillStyle = 'rgba(200,200,255,0.3)';
            for(let r of rainDrops) {
                ctx.fillRect(r.x, r.y, 2, 10);
                r.y += r.speed; r.x -= 1;
                if(r.y > GAME_H) { r.y = -10; r.x = Math.random()*GAME_W; }
                if(r.x < 0) r.x = GAME_W;
            }
        } else if(state === 'PLAYING' && isJungle) {
            // Jungle sky with tree canopy
            ctx.fillStyle = '#87CEEB';
            ctx.fillRect(0, 0, GAME_W, GAME_H);
            // Far background trees (darker, smaller)
            ctx.fillStyle = '#1B5E20';
            for(let i = 0; i < 8; i++) {
                let tx = i * 110 + 20;
                ctx.fillRect(tx, GAME_H - 350, 30, 350);
                ctx.beginPath(); ctx.arc(tx + 15, GAME_H - 350, 45, 0, Math.PI * 2); ctx.fill();
            }
            // Near background trees (lighter, bigger)
            ctx.fillStyle = '#2E7D32';
            for(let i = 0; i < 5; i++) {
                let tx = i * 190 + 50;
                ctx.fillRect(tx, GAME_H - 250, 45, 250);
                ctx.beginPath(); ctx.arc(tx + 22, GAME_H - 250, 65, 0, Math.PI * 2); ctx.fill();
            }
            // Leaf particles
            ctx.fillStyle = 'rgba(76, 175, 80, 0.6)';
            for(let l of leafParticles) {
                ctx.save(); ctx.translate(l.x, l.y); ctx.rotate(l.rot);
                ctx.fillRect(-4, -2, 8, 4); ctx.restore();
                l.y += l.speed; l.x += l.drift; l.rot += 0.02;
                if(l.y > GAME_H) { l.y = -10; l.x = Math.random() * GAME_W; }
            }
        } else if(state === 'PLAYING' && isIceLevel(currentLevel)) {
            // Ice Mountains sky — cold blue/white
            ctx.fillStyle = '#B0BEC5';
            ctx.fillRect(0, 0, GAME_W, GAME_H);
            // Distant icy mountains
            ctx.fillStyle = '#78909C';
            for(let i = 0; i < 6; i++) {
                let mx = i * 150 + 20;
                ctx.beginPath();
                ctx.moveTo(mx, GAME_H - 200);
                ctx.lineTo(mx + 50, GAME_H - 350);
                ctx.lineTo(mx + 100, GAME_H - 200);
                ctx.closePath();
                ctx.fill();
            }
            // Snow caps on mountains
            ctx.fillStyle = '#ECEFF1';
            for(let i = 0; i < 6; i++) {
                let mx = i * 150 + 20;
                ctx.beginPath();
                ctx.moveTo(mx + 30, GAME_H - 310);
                ctx.lineTo(mx + 50, GAME_H - 350);
                ctx.lineTo(mx + 70, GAME_H - 310);
                ctx.closePath();
                ctx.fill();
            }
            // Snow particles
            ctx.fillStyle = 'rgba(255, 255, 255, 0.7)';
            for(let s of snowParticles) {
                ctx.fillRect(s.x, s.y, s.size, s.size);
                s.y += s.speed;
                s.x += s.drift;
                if(s.y > GAME_H) { s.y = -5; s.x = Math.random() * GAME_W; }
                if(s.x < 0) s.x = GAME_W;
                if(s.x > GAME_W) s.x = 0;
            }
            // Blizzard effect: reduced visibility with white overlay
            if(isBlizzardLevel(currentLevel)) {
                ctx.fillStyle = 'rgba(255, 255, 255, ' + BLIZZARD_VISIBILITY + ')';
                ctx.fillRect(0, 0, GAME_W, GAME_H);
            }
        } else {
            ctx.fillStyle = '#87CEEB';
            ctx.fillRect(0, 0, GAME_W, GAME_H);
            ctx.fillStyle = 'rgba(255,255,255,0.8)';
            let ct = Date.now()/2000;
            ctx.fillRect(100+Math.sin(ct)*50, 50, 60, 20);
            ctx.fillRect(400+Math.cos(ct)*40, 80, 80, 20);
        }

        // --- DRAW LIGHTNING STRIKES ---
        if(state === 'PLAYING') {
            for(let strike of lightningStrikes) {
                if(strike.phase === 'strike') {
                    drawLightningBolt(strike.x, GAME_H, strike.seed);
                    // Screen flash
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.2)';
                    ctx.fillRect(0, 0, GAME_W, GAME_H);
                }
                if(strike.phase === 'flash') {
                    // Fading flash
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.08)';
                    ctx.fillRect(0, 0, GAME_W, GAME_H);
                }
            }
        }

        // --- DRAW ICICLE PROJECTILES ---
        if(state === 'PLAYING') {
            for(let p of icicleProjectiles) {
                ctx.fillStyle = '#B3E5FC';
                ctx.beginPath();
                ctx.moveTo(p.x + 6, p.y);
                ctx.lineTo(p.x + p.w - 6, p.y);
                ctx.lineTo(p.x + p.w/2, p.y + p.h);
                ctx.closePath();
                ctx.fill();
                ctx.fillStyle = '#E1F5FE';
                ctx.beginPath();
                ctx.moveTo(p.x + 10, p.y);
                ctx.lineTo(p.x + p.w - 10, p.y);
                ctx.lineTo(p.x + p.w/2, p.y + p.h * 0.7);
                ctx.closePath();
                ctx.fill();
                ctx.strokeStyle = '#4FC3F7'; ctx.lineWidth = 1;
                ctx.beginPath();
                ctx.moveTo(p.x + 6, p.y);
                ctx.lineTo(p.x + p.w/2, p.y + p.h);
                ctx.lineTo(p.x + p.w - 6, p.y);
                ctx.stroke();
            }
        }

        // --- WIND EFFECT ---
        if(state === 'PLAYING' && isWindLevel(currentLevel)) {
            let dir = getWindDirection(currentLevel);
            ctx.fillStyle = 'rgba(255,255,255,0.4)';
            for(let w of windParticles) {
                ctx.fillRect(w.x, w.y, 15, 2);
                w.x += w.speed * dir;
                if(dir > 0 && w.x > GAME_W) { w.x = -20; w.y = Math.random()*GAME_H; }
                if(dir < 0 && w.x < -20) { w.x = GAME_W + 20; w.y = Math.random()*GAME_H; }
            }
        }

        // --- POISON FOG (Jungle levels) ---
        if(state === 'PLAYING' && isJungleLevel(currentLevel) && player.alive) {
            fogDelayTimer++;
            // Don't start rising until delay is over (5 second warmup)
            if(fogDelayTimer > FOG_DELAY) {
                let fogSpeed = currentLevel === 15 ? 0.3 : FOG_RISE_SPEED;
                fogY -= fogSpeed;
                if(fogY < -50) fogY = -50;
            }
            let fogHeight = GAME_H - fogY;
            if(fogHeight > 0 && fogY < GAME_H) {
                // Light fog at top edge
                ctx.fillStyle = 'rgba(0, 180, 0, 0.15)';
                ctx.fillRect(0, fogY, GAME_W, fogHeight * 0.3);
                // Medium fog
                ctx.fillStyle = 'rgba(0, 140, 0, 0.25)';
                ctx.fillRect(0, fogY + fogHeight * 0.3, GAME_W, fogHeight * 0.3);
                // Dense fog at bottom
                ctx.fillStyle = 'rgba(0, 100, 0, 0.4)';
                ctx.fillRect(0, fogY + fogHeight * 0.6, GAME_W, fogHeight * 0.4);
                // Kill player only in DENSE fog (bottom 40%), not just the light edge
                if(player.alive && player.y + player.h > fogY + fogHeight * 0.6) {
                    player.alive = false;
                    spawnParticles(player.x + player.w/2, player.y + player.h/2, '#00FF00', 8);
                    setTimeout(() => { if(!player.alive) respawn(player); }, 500);
                }
            }
        }

        for (let i = particles.length - 1; i >= 0; i--) { let p = particles[i]; p.x += p.vx; p.y += p.vy; p.vy += 0.2; p.life--; if(p.life <= 0) particles.splice(i, 1); }

        if(state === 'MENU') {
            updateEntity(ghost, menuBlocks);
            menuBlocks.forEach(b => drawBlock(b));
            drawEntity(ghost, 'rgba(33, 150, 243, 0.5)');
            particles.forEach(p => { ctx.globalAlpha = p.life / 30; ctx.fillStyle = p.color; ctx.fillRect(p.x, p.y, p.size, p.size); });
            ctx.globalAlpha = 1;
        } else if(state === 'PLAYING') {
            updateEntity(player, levelBlocks);
            levelBlocks.forEach(b => drawBlock(b));
            drawEntity(player, '#2196F3');
            particles.forEach(p => { ctx.globalAlpha = p.life / 30; ctx.fillStyle = p.color; ctx.fillRect(p.x, p.y, p.size, p.size); });
            ctx.globalAlpha = 1;
        }
        requestAnimationFrame(loop);
    }

    // Input Setup
    window.addEventListener('keydown', e => {
        if(e.code === 'ArrowLeft' || e.code === 'KeyA') keys.left = true;
        if(e.code === 'ArrowRight' || e.code === 'KeyD') keys.right = true;
        if(e.code === 'Space' || e.code === 'ArrowUp' || e.code === 'KeyW') { if(!keys.jump) keys.jumpPressed = true; keys.jump = true; }
        if(e.code === 'Escape') { if(state === 'PLAYING') pauseGame(); else if(state === 'PAUSED') resumeGame(); }
    });
    window.addEventListener('keyup', e => {
        if(e.code === 'ArrowLeft' || e.code === 'KeyA') keys.left = false;
        if(e.code === 'ArrowRight' || e.code === 'KeyD') keys.right = false;
        if(e.code === 'Space' || e.code === 'ArrowUp' || e.code === 'KeyW') keys.jump = false;
    });
    function setupTouch(id, key) {
        const el = document.getElementById(id);
        el.addEventListener('touchstart', e => { e.preventDefault(); keys[key] = true; if(key==='jump') keys.jumpPressed=true; }, {passive:false});
        el.addEventListener('touchend', e => { e.preventDefault(); keys[key] = false; }, {passive:false});
        el.addEventListener('touchcancel', e => { keys[key] = false; });
    }
    setupTouch('left-btn', 'left'); setupTouch('right-btn', 'right'); setupTouch('jump-btn', 'jump');

    menuBlocks = levelsData[0]();
    ghost.x = B*2; ghost.y = 16*B - ghost.h;
    loop();


