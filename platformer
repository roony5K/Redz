    function generateBlocks(lvl) {
        if(isCustomLevel) return customBlocks;
        if(lvl <= 20) return levelsData[lvl-1]();
        let b = []; for(let i=0; i<25; i++) b.push(g(i, 17, 'grass')); b.push(portal(22, 14)); return b;
    }

    // --- GAME LOGIC ---
    function isStormLevel(lvl) { if(isCustomLevel) return document.getElementById('editor-storm').checked; return lvl === 5 || lvl === 7; } // Removed L10 thunder
    function isWindLevel(lvl) { if(isCustomLevel) return parseInt(document.getElementById('editor-wind').value) !== 0; return lvl === 6 || lvl === 7 || lvl === 10 || lvl === 15 || lvl === 19 || lvl === 20; }
    function isJungleLevel(lvl) { if(isCustomLevel) return document.getElementById('editor-fog').checked; return lvl >= 11 && lvl <= 15; }
    function isIceLevel(lvl) { if(isCustomLevel) return document.getElementById('editor-blizzard').checked; return lvl >= 16 && lvl <= 20; }
    function isBlizzardLevel(lvl) { if(isCustomLevel) return document.getElementById('editor-blizzard').checked; return lvl === 19 || lvl === 20; }
    function getWindDirection(lvl) {
        if(isCustomLevel) return parseInt(document.getElementById('editor-wind').value);
        // Level 6: right, Level 7: right, Level 10: right, Level 19: left, Level 20: right
        if(lvl === 19) return -1;
        return 1; // 1 = right, -1 = left
    }

    // isOnVine removed — vines are now solid platforms, not climbable

    function startGame(lvl) {
        if(lvl !== 99) isCustomLevel = false;
        state = 'PLAYING';
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById('hud').style.display = 'flex';
        document.getElementById('level-text').innerText = "LEVEL " + lvl;
        if(isMobile) document.getElementById('mobile-controls').classList.add('mobile-visible');

        player.hasWallClimb = false;
        levelBlocks = generateBlocks(lvl);
        lightningStrikes = [];
        lightningCooldown = 2; // Give player 2 seconds before first strike
        icicleProjectiles = [];

        // Reset fog for all levels
        fogY = FOG_INITIAL_Y;
        fogDelayTimer = 0;

        let spawnRow, spawnCol;
        if(isCustomLevel && lvl === 99) {
            spawnRow = edStartPos.r;
            spawnCol = edStartPos.c;
        } else {
            spawnRow = levelSpawnRow[lvl] || 17;
            spawnCol = levelSpawnCol[lvl] || 2;
        }
        // Player stands ON the spawnRow: feet at top of spawnRow
        player.x = spawnCol * B; player.y = spawnRow * B - player.h;
        player.vx = 0; player.vy = 0; player.alive = true; player.grounded = false; player.canJump = true;
        player.climbing = false; player.onVineDir = 0; player.standingOn = 'air';

        // Wind UI
        if(isWindLevel(lvl)) {
            document.getElementById('wind-text').style.display = 'block';
            let dir = getWindDirection(lvl);
            document.getElementById('wind-text').innerText = dir > 0 ? "WIND >>" : "<< WIND";
        } else {
            document.getElementById('wind-text').style.display = 'none';
        }

        // Fog UI
        if(isJungleLevel(lvl)) {
            document.getElementById('fog-text').style.display = 'block';
        } else {
            document.getElementById('fog-text').style.display = 'none';
        }
        // Wind UI for ice blizzard
        if(isBlizzardLevel(lvl)) {
            document.getElementById('wind-text').style.display = 'block';
            let dir = getWindDirection(lvl);
            document.getElementById('wind-text').innerText = dir > 0 ? "BLIZZARD >>" : "<< BLIZZARD";
            document.getElementById('wind-text').style.color = '#81D4FA';
        } else if(!isWindLevel(lvl)) {
            document.getElementById('wind-text').style.display = 'none';
            document.getElementById('wind-text').style.color = '#00bcd4';
        }
    }

    function respawn(entity) {
        let spawnRow, spawnCol;
        if(isCustomLevel && currentLevel === 99) {
            spawnRow = edStartPos.r;
            spawnCol = edStartPos.c;
        } else {
            spawnRow = levelSpawnRow[currentLevel] || 17;
            spawnCol = levelSpawnCol[currentLevel] || 2;
        }
        entity.x = spawnCol * B; entity.y = spawnRow * B - entity.h;
        entity.vx = 0; entity.vy = 0; entity.alive = true; entity.grounded = false; entity.canJump = true;
        entity.climbing = false; entity.onVineDir = 0; entity.standingOn = 'air';
        for(let b of levelBlocks) {
            if(b.origType === 'spike') b.type = 'spike';
            if(b.origType === 'fake_grass') { b.type = 'fake_grass'; b.timer = 0; }
            if(b.origType === 'quicksand') { b.type = 'quicksand'; b.sinkTimer = 0; }
            if(b.origType === 'icicle') { b.icicleTimer = Math.floor(Math.random() * 60); }
            b.timer = 0;
        }
        // Reset fog on respawn so player gets a fair chance
        if(isJungleLevel(currentLevel)) { fogY = FOG_INITIAL_Y; fogDelayTimer = 0; }
    }

    function spawnParticles(x, y, color, count) { for(let i=0; i<count; i++) { particles.push({ x, y, vx: (Math.random()-0.5)*4, vy: (Math.random()-0.5)*4 - 1, life: 15+Math.random()*15, color, size: 3+Math.random()*3 }); } }

    function doJump(entity) {
        if(!entity.canJump) return;
        // Vines are solid platforms now — no special climbing jump logic
        if(entity.grounded) {
            let jf = JUMP_FORCE;
            if(entity.standingOn === 'mud') jf *= MUD_JUMP_MULT;
            if(entity.standingOn === 'quicksand') jf *= 0.5;
            if(entity.standingOn === 'snow') jf *= SNOW_JUMP_MULT;
            entity.vy = jf; entity.grounded = false; entity.canJump = false;
            entity.targetScaleX = 0.6; entity.targetScaleY = 1.4;
            if(entity === player) spawnParticles(entity.x+entity.w/2, entity.y+entity.h, '#fff', 4);
            // Reset quicksand timer on the block player is jumping from
            for(let b of levelBlocks) { if(b.type === 'quicksand' && player.x + player.w > b.x && player.x < b.x + b.w) b.sinkTimer = 0; }
            // Vines are solid platforms — no auto-grab needed
        } else if(entity.onWall !== 0) {
            entity.vy = JUMP_FORCE; entity.vx = WALL_JUMP_X * -entity.onWall; entity.onWall = 0; entity.canJump = false;
            entity.targetScaleX = 0.6; entity.targetScaleY = 1.4;
            if(entity === player) spawnParticles(entity.x + (entity.onWall > 0 ? entity.w : 0), entity.y+entity.h/2, '#8B5A2B', 6);
        }
    }

    function isSolidType(type) {
        return type === 'grass' || type === 'dirt' || type === 'flower' || type === 'fake_grass' || type === 'trigger' || type === 'vine' || type === 'mud' || type === 'hanging_vine' || type === 'quicksand' || type === 'ice' || type === 'snow' || type === 'frozen_grass' || type === 'fake_ice';
    }
    // isSolidForClimbing removed — vines are now solid like other blocks

    function isWallType(type) {
        return type === 'grass' || type === 'dirt' || type === 'flower' || type === 'fake_grass' || type === 'vine' || type === 'ice' || type === 'frozen_grass' || type === 'fake_ice';
    }

    // --- VINE CLIMBING: Check if entity overlaps a vine block ---
    function isOnVine(entity, blocks) {
        for(let b of blocks) {
            if(b.type !== 'vine' && b.type !== 'hanging_vine') continue;
            // Check if player overlaps the vine block (generous detection)
            if(entity.x + entity.w > b.x + 2 && entity.x < b.x + b.w - 2 &&
               entity.y + entity.h > b.y + 2 && entity.y < b.y + b.h - 2) {
                return b;
            }
        }
        return null;
    }

    function updateEntity(entity, blocks) {
        if(!entity.alive) return;

        if(entity === ghost) {
            entity.vx = SPEED;
            let wallAhead = false, groundAhead = false;
            for(let b of blocks) {
                if(!isWallType(b.type)) continue;
                if(b.x >= entity.x + entity.w && b.x < entity.x + entity.w + 15 && b.y < entity.y + entity.h && b.y + b.h > entity.y) wallAhead = true;
                if(b.x > entity.x + entity.w && b.x < entity.x + B*4 && b.y > entity.y) groundAhead = true;
            }
            if((wallAhead || !groundAhead) && entity.grounded) doJump(entity);
            if(entity.onWall !== 0) doJump(entity);
            if(entity.x > GAME_W) { entity.x = 0; entity.y = 16*B - entity.h; entity.vx = SPEED; entity.vy = 0; entity.grounded = false; }
        } else {
            // Check if on ice for slippery movement
            let onIce = entity.grounded && entity.standingOn === 'ice';
            if(onIce) {
                // Ice: gradual acceleration, very low deceleration
                if(keys.left) entity.vx -= 0.5;
                else if(keys.right) entity.vx += 0.5;
                else { entity.vx *= ICE_SLIDE_DECEL; }
                if(Math.abs(entity.vx) > ICE_SLIDE_MAX) entity.vx = Math.sign(entity.vx) * ICE_SLIDE_MAX;
            } else {
                if(keys.left) entity.vx = -SPEED;
                else if(keys.right) entity.vx = SPEED;
                else { entity.vx *= 0.6; }
            }

            // MUD: slow movement (apply BEFORE position update so it actually works!)
            if(entity.grounded && entity === player) {
                if(entity.standingOn === 'mud') entity.vx *= MUD_SPEED_MULT;
                if(entity.standingOn === 'quicksand') entity.vx *= 0.35;
                // SNOW: slows like mud but doesn't sink
                if(entity.standingOn === 'snow') entity.vx *= SNOW_SPEED_MULT;
            }

            if(keys.jumpPressed) { doJump(entity); keys.jumpPressed = false; }
            if(entity.x < 0) entity.x = 0;
            if(entity.x + entity.w > GAME_W) entity.x = GAME_W - entity.w;

            // Wind Logic — pushes player even when grounded (slowly) and faster when airborne
            if(isWindLevel(currentLevel)) {
                let dir = getWindDirection(currentLevel);
                let isBlizzard = isBlizzardLevel(currentLevel);
                let windF = isBlizzard ? BLIZZARD_WIND_FORCE : WIND_FORCE;
                let windG = isBlizzard ? BLIZZARD_WIND_GROUND : WIND_FORCE_GROUND;
                if(!entity.grounded) {
                    entity.vx += windF * dir;
                } else {
                    entity.vx += windG * dir;
                }
            }
        }

        entity.vy += GRAVITY;
        if(entity.vy > 16) entity.vy = 16;

        // --- VINE CLIMBING MECHANIC ---
        // Right = climb up, Left = climb down, No input = slow slide down
        // Can also jump off vine
        if(entity === player && (entity.climbing || !entity.grounded)) {
            let vineBlock = isOnVine(entity, blocks);
            if(vineBlock && !entity.climbing) {
                // Auto-grab vine when overlapping it while airborne
                entity.climbing = true;
                entity.onVineDir = (entity.x + entity.w/2 < vineBlock.x + vineBlock.w/2) ? 1 : -1;
            }
            if(entity.climbing) {
                let vineBlock2 = isOnVine(entity, blocks);
                if(vineBlock2) {
                    // Anchor player horizontally to the vine center
                    let vineCenterX = vineBlock2.x + vineBlock2.w/2 - entity.w/2;
                    entity.x += (vineCenterX - entity.x) * 0.3; // Smooth snap to vine
                    entity.vx = 0;

                    // Right key = climb UP
                    if(keys.right) {
                        entity.vy = -VINE_CLIMB_SPEED;
                        entity.canJump = true;
                    }
                    // Left key = climb DOWN
                    else if(keys.left) {
                        entity.vy = VINE_CLIMB_SPEED;
                        entity.canJump = true;
                    }
                    // No key = slow slide down
                    else {
                        entity.vy = VINE_SLIDE_SPEED;
                        entity.canJump = true;
                    }

                    // Jump key = leap off vine (with some sideways momentum)
                    if(keys.jumpPressed) {
                        entity.climbing = false;
                        entity.vy = JUMP_FORCE;
                        entity.vx = (entity.onVineDir || 1) * 5; // Leap off to the side
                        keys.jumpPressed = false;
                    }
                } else {
                    // No longer overlapping a vine — stop climbing
                    entity.climbing = false;
                }
            }
        }

        // If player lands on actual solid ground, stop climbing
        if(entity === player && entity.grounded && entity.standingOn !== 'vine' && entity.standingOn !== 'hanging_vine') {
            entity.climbing = false;
        }

        // Ghost wall-climb (ghost still uses wall-slide mechanic)
        entity.onWall = 0;
        if(entity === ghost && !entity.grounded && entity.hasWallClimb) {
            let pressing = (keys.left || keys.right || entity === ghost);
            if(pressing) {
                let wallLeft = checkWall(entity, -1, blocks);
                let wallRight = checkWall(entity, 1, blocks);
                if(wallLeft) entity.onWall = -1;
                if(wallRight) entity.onWall = 1;
                if(entity.onWall !== 0 && entity.vy > 0) {
                    entity.vy = 2.5;
                    entity.canJump = true;
                }
            }
        }

        entity.x += entity.vx; checkCollision(entity, blocks, 'x');
        let wasInAir = !entity.grounded;
        entity.y += entity.vy; entity.grounded = false; entity.standingOn = 'air'; checkCollision(entity, blocks, 'y');

        if(entity.grounded && wasInAir && entity === player) {
            entity.targetScaleX = 1.3; entity.targetScaleY = 0.7;
            spawnParticles(entity.x+entity.w/2, entity.y+entity.h, '#fff', 5);
        }

        // Mud/quicksand speed already applied above (before position update)

        if(entity.y > GAME_H + 100) { entity.alive = false; if(entity._respawnTimer) clearTimeout(entity._respawnTimer); entity._respawnTimer = setTimeout(() => { if(!entity.alive) respawn(entity); }, 500); }

        entity.scaleX += (entity.targetScaleX - entity.scaleX) * 0.2;
        entity.scaleY += (entity.targetScaleY - entity.scaleY) * 0.2;
        entity.targetScaleX += (1 - entity.targetScaleX) * 0.2;
        entity.targetScaleY += (1 - entity.targetScaleY) * 0.2;
    }

    function checkWall(entity, dir, blocks) {
        for(let b of blocks) {
            if(!isWallType(b.type)) continue;
            if(entity.y + entity.h > b.y + 4 && entity.y < b.y + b.h - 4) {
                if(dir === -1 && entity.x <= b.x + b.w && entity.x + entity.w >= b.x + b.w) return true;
                if(dir === 1 && entity.x + entity.w >= b.x && entity.x <= b.x) return true;
            }
        } return false;
    }

    function checkCollision(entity, blocks, axis) {
        for(let b of blocks) {
            if(!rectCollide(entity, b)) continue;

            if(b.type === 'lava') { if(entity.alive) { entity.alive = false; setTimeout(() => { if(!entity.alive) respawn(entity); }, 500); } return; }
            if(b.type === 'portal' && entity === player) { nextLevel(); return; }

            // Thorn bush: kills on ANY contact from ANY direction
            if(b.type === 'thorn_bush') { if(entity.alive) { entity.alive = false; setTimeout(() => { if(!entity.alive) respawn(entity); }, 500); } return; }

            // Spike_visible: only kill from TOP contact, not side/bottom
            if(b.type === 'spike_visible') {
                if(axis === 'y') {
                    const playerBottom = entity.y + entity.h;
                    const playerCenterY = entity.y + entity.h / 2;
                    const spikeTop = b.y;
                    // Kill only if player center is ABOVE spike top and bottom barely crosses into spike
                    if(playerCenterY < spikeTop && playerBottom > spikeTop && playerBottom < spikeTop + 16 && entity.vy > 0) {
                        if(entity.alive) { entity.alive = false; setTimeout(() => { if(!entity.alive) respawn(entity); }, 500); }
                    }
                }
                continue; // Don't treat as solid, keep checking other blocks
            }

            // Spike_up: kills on any contact (active/extended spike)
            if(b.type === 'spike_up') { if(entity.alive) { entity.alive = false; setTimeout(() => { if(!entity.alive) respawn(entity); }, 500); } return; }

            // Trigger: activates adjacent hidden spikes
            if(b.type === 'trigger' && axis === 'y' && entity.vy >= 0) {
                for(let s of blocks) {
                    if(s.origType === 'spike' && Math.abs(s.x - b.x) === B && s.y === b.y) {
                        s.type = 'spike_up'; s.timer = 90;
                    }
                }
            }

            // Solid block collision
            if(isSolidType(b.type)) {
                // Vine: Grab from side to start climbing (player only)
                if(b.type === 'vine' && entity === player && axis === 'x' && !entity.climbing) {
                    entity.climbing = true;
                    entity.onVineDir = (entity.x + entity.w/2 < b.x + b.w/2) ? 1 : -1;
                    entity.vy = 0;
                    entity.vx = 0;
                    continue; // Don't push player out — they're climbing!
                }
                // Vine/hanging_vine: Skip collision if player is actively climbing
                if((b.type === 'vine' || b.type === 'hanging_vine') && entity === player && entity.climbing) continue;

                if(axis === 'x') { if(entity.vx > 0) { entity.x = b.x - entity.w; entity.vx = 0; } else if(entity.vx < 0) { entity.x = b.x + b.w; entity.vx = 0; } }
                if(axis === 'y') {
                    if(entity.vy > 0) { entity.y = b.y - entity.h; entity.vy = 0; entity.grounded = true; entity.canJump = true; entity.standingOn = b.type; }
                    else if(entity.vy < 0) { entity.y = b.y + b.h; entity.vy = 0; }
                }
            }
        }
    }

    function rectCollide(r1, r2) { return r1.x < r2.x + r2.w && r1.x + r1.w > r2.x && r1.y < r2.y + r2.h && r1.y + r1.h > r2.y; }

    function nextLevel() {
        currentLevel++;
        if(currentLevel > 20) { alert("You beat all 20 Levels!"); returnToMenu(); return; }
        // Clean transition — reset all velocity
        player.vx = 0;
        player.vy = 0;
        startGame(currentLevel);
    }

