<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Pixel Block Obby</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background-color: #111; overflow: hidden;
            touch-action: manipulation; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            -webkit-tap-highlight-color: transparent;
            display: flex; justify-content: center; align-items: center; height: 100vh;
        }
        /* When editor is open, body must NOT clip overflow */
        body.editor-active { overflow: visible; }
        canvas { display: block; image-rendering: pixelated; touch-action: none; border: 4px solid #222; margin: 0 auto; }

        .screen {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            display: none; flex-direction: column; justify-content: center; align-items: center;
            background: rgba(0, 0, 0, 0.9); z-index: 100; color: white; padding: 20px;
        }
        .screen.active { display: flex; }
        h1, h2 { text-shadow: 3px 3px 0 #000; margin-bottom: 20px; text-align: center; }
        h1 { font-size: 48px; } h2 { font-size: 36px; }

        button {
            font-family: inherit; font-size: 28px; font-weight: bold; padding: 15px 40px;
            border: none; border-radius: 10px; cursor: pointer; color: #fff; text-shadow: 2px 2px 0 #000;
            border-bottom: 5px solid rgba(0,0,0,0.3); margin: 8px; background-color: #4CAF50; touch-action: manipulation;
        }
        button:active { border-bottom: 2px solid rgba(0,0,0,0.3); transform: translateY(3px); }
        .btn-red { background-color: #f44336; } .btn-blue { background-color: #2196F3; } .btn-grey { background-color: #607D8B; }

        .level-grid-container {
            width: 90%; max-width: 400px; height: 50vh; overflow-y: auto; -webkit-overflow-scrolling: touch;
            background: rgba(0,0,0,0.4); border-radius: 12px; padding: 15px; border: 2px solid rgba(255,255,255,0.2); margin: 10px 0;
        }
        .level-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
        .level-btn {
            aspect-ratio: 1; font-size: 24px; display: flex; justify-content: center; align-items: center;
            background-color: #4CAF50; color: white; border-radius: 8px; border-bottom: 4px solid rgba(0,0,0,0.3); padding: 0;
        }
        .level-btn:active { border-bottom: 2px solid rgba(0,0,0,0.3); transform: translateY(2px); }

        .setting-row { display: flex; justify-content: space-between; align-items: center; width: 80%; max-width: 300px; margin: 10px 0; font-size: 28px; }
        .toggle-switch { width: 60px; height: 30px; background-color: #555; border-radius: 15px; position: relative; cursor: pointer; border-bottom: none; }
        .toggle-switch.active { background-color: #4CAF50; }
        .toggle-knob { width: 26px; height: 26px; background-color: white; border-radius: 50%; position: absolute; top: 2px; left: 2px; transition: 0.2s; }
        .toggle-switch.active .toggle-knob { left: 32px; }

        #hud { position: absolute; top: 20px; left: 20px; right: 20px; display: none; justify-content: space-between; align-items: center; z-index: 50; }
        #level-text { color: #fff; font-size: 32px; font-weight: bold; text-shadow: 3px 3px 0 #000; }
        #wind-text { color: #00bcd4; font-size: 24px; font-weight: bold; text-shadow: 2px 2px 0 #000; display: none; }
        #fog-text { color: #4CAF50; font-size: 24px; font-weight: bold; text-shadow: 2px 2px 0 #000; display: none; }
        #pause-btn { font-size: 28px; padding: 10px 20px; margin: 0; }

        #mobile-controls { position: absolute; bottom: 0; left: 0; width: 100%; height: 180px; display: none !important; z-index: 60; }
        /* Only show mobile controls on actual touch mobile devices */
        @media (pointer: coarse) and (max-width: 900px) {
            #mobile-controls.mobile-visible { display: block !important; }
        }
        .touch-btn {
            position: absolute; width: 90px; height: 90px; background: rgba(255,255,255,0.3); border: 4px solid rgba(255,255,255,0.6);
            border-radius: 50%; color: #fff; font-size: 35px; font-weight: bold; display: flex; justify-content: center; align-items: center;
            user-select: none; -webkit-user-select: none; touch-action: none;
        }
        #left-btn { left: 30px; bottom: 40px; } #right-btn { left: 150px; bottom: 40px; }
        #jump-btn { right: 30px; bottom: 40px; width: 120px; height: 90px; border-radius: 45px; font-size: 28px; }

        #unlock-popup {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            background: rgba(0,0,0,0.9); color: #FFEB3B; font-size: 36px; font-weight: bold;
            padding: 20px; border-radius: 12px; text-shadow: 3px 3px 0 #000; border: 4px solid #FFEB3B;
            display: none; z-index: 200; text-align: center;
        }
    
        /* === LEVEL EDITOR === */
        #editor-screen {
            display: none;
            flex-direction: column !important;
            align-items: stretch !important;
            justify-content: flex-start !important;
            padding: 0 !important;
            position: fixed !important; top: 0; left: 0; width: 100%; height: 100%;
            background: #111; z-index: 100;
            overflow: hidden;
        }
        #editor-screen.active { display: flex !important; }
        #editor-toolbar {
            display: flex;
            flex-direction: column;
            gap: 4px;
            padding: 6px 8px;
            background: #2a2a2a;
            border-bottom: 2px solid #444;
            flex-shrink: 0;
            width: 100%;
            box-sizing: border-box;
        }
        #editor-toolbar-top {
            display: flex;
            gap: 4px;
            align-items: center;
            flex-wrap: nowrap;
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
            touch-action: pan-x;
            width: 100%;
        }
        #editor-toolbar-top::-webkit-scrollbar { display: none; }
        #editor-toolbar h2 { font-size: 14px; color: #4CAF50; white-space: nowrap; flex-shrink: 0; }
        #editor-palette-scroll {
            overflow-x: scroll;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
            flex-shrink: 0;
            padding-bottom: 4px;
            touch-action: pan-x;
        }
        #editor-palette-scroll::-webkit-scrollbar { height: 3px; background: #333; }
        #editor-palette-scroll::-webkit-scrollbar-thumb { background: #555; border-radius: 2px; }
        #editor-palette { display: flex; gap: 5px; align-items: center; flex-wrap: nowrap; min-width: min-content; }
        .editor-tool-btn {
            width: 38px; height: 38px; border: 2px solid #555; border-radius: 6px; cursor: pointer;
            display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px;
            color: #fff; user-select: none; transition: transform .05s; position: relative;
            touch-action: manipulation; flex-shrink: 0;
        }
        .editor-tool-btn:hover { transform: scale(1.12); z-index: 2; }
        .editor-tool-btn.active { border-color: #fff; box-shadow: 0 0 0 2px #2196F3; z-index: 3; }
        .editor-tool-name {
            font-size: 9px; position: absolute; bottom: 1px; left: 0; right: 0; text-align: center;
            color: rgba(255,255,255,0.7); overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
            pointer-events: none;
        }
        #editor-area {
            flex: 1;
            min-height: 0;
            min-width: 0;
            width: 100%;
            overflow: scroll;
            -webkit-overflow-scrolling: touch;
            background: #1a1a1a;
            padding: 6px;
            touch-action: pan-x pan-y;
            box-sizing: border-box;
        }
        #editor-grid {
            display: grid;
            grid-template-columns: 26px repeat(25, var(--cs));
            grid-template-rows: 18px repeat(19, var(--cs));
            gap: 1px;
            background: #333;
            flex-shrink: 0;
            border: 2px solid #555;
            /* Do NOT set touch-action here — let #editor-area handle scroll */
            width: max-content;
        }
        .editor-cell {
            width: var(--cs); height: var(--cs);
            background: #e8e8e8;
            display: flex; align-items: center; justify-content: center;
            font-size: calc(var(--cs) * 0.38); font-weight: bold; color: #222;
            cursor: crosshair; position: relative;
            border: 1px solid rgba(0,0,0,0.06);
            -webkit-user-select: none; user-select: none;
            touch-action: pan-x pan-y; /* allow scroll to bubble up */
        }
        .editor-cell:hover { filter: brightness(1.15); z-index: 2; }
        .editor-start-marker {
            position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
            font-size: calc(var(--cs) * 0.55); font-weight: bold; color: #fff; text-shadow: 0 0 3px #000;
            pointer-events: none; background: rgba(33,150,243,0.35);
        }
        .editor-row-label, .editor-col-label {
            display: flex; align-items: center; justify-content: center;
            font-size: 9px; color: #aaa; background: #2a2a2a; user-select: none;
        }
        .editor-row-label { width: 26px; height: var(--cs); }
        .editor-col-label { width: var(--cs); height: 18px; }
        .editor-corner { width: 26px; height: 18px; background: #2a2a2a; }
        #editor-io {
            display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
            background: #2a2a2a; padding: 20px; border-radius: 10px; border: 2px solid #555; z-index: 200;
            flex-direction: column; gap: 10px; max-width: 95vw;
        }
        #editor-io h3 { margin-bottom: 5px; }
        #editor-io textarea {
            width: 720px; max-width: 85vw; height: 480px; max-height: 60vh;
            font-family: 'Courier New', monospace; font-size: 13px; line-height: 1.4;
            background: #111; color: #0f0; border: 1px solid #555; padding: 8px; resize: none;
        }
</style>
</head>
<body>

    <canvas id="game"></canvas>

    <div id="menu-screen" class="screen active">
        <h1>PIXEL BLOCK OBBY</h1>
        <button onclick="handlePlayClick()">PLAY</button>
        <button class="btn-blue" onclick="showScreen('level-screen')">LEVELS</button>
        <button class="btn-grey" onclick="showScreen('settings-screen')">SETTINGS</button>
        <button class="btn-blue" onclick="showScreen('editor-screen'); editorInit();">LEVEL EDITOR</button>
    </div>
    <div id="level-screen" class="screen">
        <h2>SELECT LEVEL</h2>
        <div class="level-grid-container"><div class="level-grid" id="level-grid-inner"></div></div>
        <button class="btn-grey" onclick="goBackFromLevels()">BACK</button>
    </div>
    <div id="settings-screen" class="screen">
        <h2>SETTINGS</h2>
        <div class="setting-row"><span>Music</span><div class="toggle-switch active" onclick="toggleSetting(this)"><div class="toggle-knob"></div></div></div>
        <div class="setting-row"><span>Sound</span><div class="toggle-switch active" onclick="toggleSetting(this)"><div class="toggle-knob"></div></div></div>
        <button class="btn-red" onclick="handleResetClick()" style="margin-top: 30px;">RESET PROGRESS</button>
        <button class="btn-grey" onclick="goBackFromSettings()">BACK</button>
    </div>
    <div id="pause-screen" class="screen">
        <h2>PAUSED</h2>
        <button onclick="resumeGame()">RESUME</button>
        <button class="btn-blue" onclick="showScreen('level-screen')">LEVELS</button>
        <button class="btn-grey" onclick="showScreen('settings-screen')">SETTINGS</button>
        <button class="btn-blue" onclick="showScreen('editor-screen'); editorInit();">LEVEL EDITOR</button>
        <button class="btn-red" onclick="returnToMenu()">MAIN MENU</button>
    </div>

    <div id="hud">
        <div id="level-text">LEVEL 1</div>
        <div id="wind-text">WIND >></div>
        <div id="fog-text">FOG RISING!</div>
        <button id="pause-btn" class="btn-grey" onclick="pauseGame()">||</button>
    </div>
    <div id="unlock-popup"></div>

    <div id="mobile-controls">
        <div id="left-btn" class="touch-btn"><</div>
        <div id="right-btn" class="touch-btn">></div>
        <div id="jump-btn" class="touch-btn">JUMP</div>
    </div>

<script>
    const canvas = document.getElementById('game');
    const ctx = canvas.getContext('2d');

    const GAME_W = 800;
    const GAME_H = 608;
    canvas.width = GAME_W;
    canvas.height = GAME_H;

    function resize() {
        let scale = Math.min(window.innerWidth / GAME_W, window.innerHeight / GAME_H);
        canvas.style.width = (GAME_W * scale) + 'px';
        canvas.style.height = (GAME_H * scale) + 'px';
    }
    window.addEventListener('resize', resize); resize();

    let isMobile = window.matchMedia('(pointer: coarse) and (max-width: 900px)').matches && ('ontouchstart' in window || navigator.maxTouchPoints > 0);
    window.addEventListener('resize', () => { isMobile = window.matchMedia('(pointer: coarse) and (max-width: 900px)').matches && ('ontouchstart' in window || navigator.maxTouchPoints > 0); });
    let state = 'MENU'; let previousState = 'MENU';
    let isCustomLevel = false;
    let currentLevel = 1;
    let maxLevel = 20;

    const B = 32;
    // --- APPROVED TIGHT PHYSICS ---
    const GRAVITY = 0.7;
    const JUMP_FORCE = -12.0;
    const SPEED = 5.0;
    const WALL_JUMP_X = 7;
    const WIND_FORCE = 0.5; // Pushes player right (air)
    const WIND_FORCE_GROUND = 0.15; // Slow push when grounded

    let keys = { left: false, right: false, jump: false, jumpPressed: false };

    function createEntity() {
        return { x:0, y:0, w:24, h:28, vx:0, vy:0, grounded:false, onWall:0, alive:true, canJump:true, hasWallClimb:false, standingOn:'grass', scaleX:1, scaleY:1, targetScaleX:1, targetScaleY:1, climbing:false, onVineDir:0 };
    }
    let player = createEntity();
    let ghost = createEntity(); ghost.hasWallClimb = true;
    let levelBlocks = [], menuBlocks = [];
    let customBlocks = [];
    // Per-level spawn positions (row of ground beneath player feet)
    const levelSpawnRow = [0, 17, 17, 17, 17, 17, 14, 14, 14, 7, 12, 18, 18, 1, 18, 18, 17, 17, 17, 17, 17];
    // Per-level spawn column (in grid units)
    const levelSpawnCol = [0, 2, 2, 2, 2, 2, 2, 2, 2, 0, 1, 5, 0, 22, 0, 0, 2, 2, 2, 2, 2];
    let particles = [];
    let windParticles = [];
    for(let i=0; i<30; i++) windParticles.push({x: Math.random()*GAME_W, y: Math.random()*GAME_H, speed: 10+Math.random()*10});

    // --- LIGHTNING STRIKE SYSTEM (Sky strikes, NOT blocks) ---
    let lightningStrikes = []; // {x, phase, timer}  phases: 'warning', 'strike', 'flash', 'done'
    let lightningCooldown = 0; // Time until next strike
    let nextStrikeDelay = 3; // seconds between strikes

    // --- RAIN ---
    let rainDrops = [];
    for(let i=0; i<100; i++) rainDrops.push({x: Math.random()*GAME_W, y: Math.random()*GAME_H, speed: 5+Math.random()*5});

    // --- CRUMBLE SYSTEM ---
    // Fake grass blocks crumble when stood on:
    // timer 0-3: solid (normal)
    // timer 4-8: shaking (still solid but about to break)
    // timer 9+: crumbled (non-solid, type changes to 'air') — INSTANT break!
    const CRUMBLE_SHAKE_START = 3;
    const CRUMBLE_FALL_START = 8;

    // --- JUNGLE BIOME ---
    const MUD_SPEED_MULT = 0.5;
    const MUD_JUMP_MULT = 0.6;
    // Vine climbing: right = climb up, left = climb down, no input = slow slide
    const VINE_CLIMB_SPEED = 3.5;
    const VINE_SLIDE_SPEED = 1.0;
    const QUICKSAND_DEATH_TIMER = 180; // 3 seconds before death (was 120/2sec, too fast)
    // --- ICE MOUNTAINS BIOME ---
    const ICE_SLIDE_DECEL = 0.92; // Friction when on ice (higher = more slippery, 1.0 = no friction)
    const ICE_SLIDE_MAX = 8.0; // Max slide speed on ice
    const SNOW_SPEED_MULT = 0.5; // Snow slows like mud
    const SNOW_JUMP_MULT = 0.85; // Snow slightly reduces jump
    const BLIZZARD_WIND_FORCE = 0.8; // Stronger than normal wind
    const BLIZZARD_WIND_GROUND = 0.25;
    const BLIZZARD_VISIBILITY = 0.4; // Reduced visibility (alpha of white overlay)
    // Icicle system
    let icicleProjectiles = []; // Falling icicle projectiles {x, y, vy, timer}
    let snowParticles = [];
    for(let i=0; i<60; i++) snowParticles.push({x: Math.random()*800, y: Math.random()*608, speed: 1+Math.random()*2, drift: (Math.random()-0.5)*1.5, size: 2+Math.random()*3});
    const FOG_RISE_SPEED = 0.15; // Slower fog rise
    const FOG_INITIAL_Y = GAME_H + 400; // Start further down (more time before fog appears)
    const FOG_DELAY = 300; // Frames before fog starts rising (5 seconds)
    let fogY = FOG_INITIAL_Y;
    let fogDelayTimer = 0;
    let leafParticles = [];
    for(let i=0; i<20; i++) leafParticles.push({x: Math.random()*GAME_W, y: Math.random()*GAME_H, speed: 1+Math.random()*2, drift: (Math.random()-0.5)*0.5, rot: Math.random()*Math.PI*2});

    // --- UI LOGIC ---
    function showScreen(id) { document.querySelectorAll('.screen').forEach(s => s.classList.remove('active')); document.getElementById(id).classList.add('active'); if(id === 'level-screen') populateLevelGrid(); document.body.classList.toggle('editor-active', id === 'editor-screen'); }
    function populateLevelGrid() {
        const container = document.getElementById('level-grid-inner'); container.innerHTML = '';
        for(let i=1; i<=20; i++) {
            let btn = document.createElement('button');
            btn.className = 'level-btn';
            btn.innerText = i;
            if(i >= 11 && i <= 15) btn.style.backgroundColor = '#2E7D32'; // Jungle color
            if(i >= 16) btn.style.backgroundColor = '#1565C0'; // Ice Mountains color
            btn.onclick = () => { currentLevel = i; startGame(i); };
            container.appendChild(btn);
        }
    }
    function handlePlayClick() { currentLevel = 1; startGame(currentLevel); }
    function handleResetClick() { maxLevel = 20; alert("Progress Reset!"); populateLevelGrid(); }
    function toggleSetting(el) { el.classList.toggle('active'); }
    function goBackFromLevels() { if(state === 'PAUSED') showScreen('pause-screen'); else showScreen('menu-screen'); }
    function goBackFromSettings() { if(state === 'PAUSED' || previousState === 'PAUSED') showScreen('pause-screen'); else showScreen('menu-screen'); }
    function pauseGame() { state = 'PAUSED'; previousState = 'PAUSED'; showScreen('pause-screen'); if(isMobile) document.getElementById('mobile-controls').classList.remove('mobile-visible'); }
    function resumeGame() { state = 'PLAYING'; document.querySelectorAll('.screen').forEach(s => s.classList.remove('active')); if(isMobile) document.getElementById('mobile-controls').classList.add('mobile-visible'); }
    function returnToMenu() { isCustomLevel = false; state = 'MENU'; previousState = 'MENU'; showScreen('menu-screen'); document.getElementById('hud').style.display = 'none'; if(isMobile) document.getElementById('mobile-controls').classList.remove('mobile-visible'); ghost.x=50; ghost.y=400; }

    // --- LEVEL DATA ---
    function g(x, y, type) { return {x: x*B, y: y*B, w:B, h:B, type: type, origType: type, timer: 0, sinkTimer: 0}; }
    function portal(x, y) { return {x: x*B, y: y*B, w:B, h:B*3, type: 'portal', origType: 'portal', timer:0, sinkTimer: 0}; }
    function row(x1, x2, y, type) { let b=[]; for(let i=x1; i<=x2; i++) b.push(g(i, y, type)); return b; }
    function hangingVine(x, y, range, speed) {
        return {x: x*B, y: y*B, w:B, h:B, type: 'hanging_vine', origType: 'hanging_vine', timer: 0, swingCenter: x*B, swingRange: range*B, swingSpeed: speed, swingTimer: Math.random()*Math.PI*2, sinkTimer: 0, anchorX: x*B, anchorY: (y-2)*B};
    }

    const levelsData = [
        // L1
        () => [...row(0, 4, 17, 'grass'), g(7, 17, 'grass'), g(8, 17, 'grass'), g(9, 17, 'grass'), g(12, 16, 'grass'), g(16, 17, 'grass'), ...row(19, 24, 17, 'grass'), portal(22, 14)],
        // L2
        () => [...row(0, 3, 17, 'grass'), g(6, 15, 'grass'), g(10, 13, 'grass'), g(11, 13, 'grass'), g(14, 16, 'grass'), g(17, 17, 'grass'), ...row(19, 24, 17, 'grass'), portal(22, 14)],
        // L3
        () => [...row(0, 3, 17, 'grass'), g(6, 15, 'grass'), g(9, 13, 'grass'), g(10, 13, 'grass'), g(11, 11, 'grass'), g(14, 11, 'grass'), g(17, 15, 'grass'), ...row(19, 24, 17, 'grass'), portal(22, 14)],
        // L4
        () => [...row(0, 3, 17, 'grass'), g(4, 17, 'trigger'), g(5, 17, 'spike'), g(6, 17, 'grass'), g(9, 15, 'grass'), g(13, 17, 'trigger'), g(14, 17, 'spike'), g(15, 17, 'grass'), g(18, 15, 'grass'), g(21, 17, 'trigger'), g(22, 17, 'spike'), g(23, 17, 'grass'), portal(23, 14)],
        // L5 — Lava Crossing + Lightning Strikes from Sky
        () => {
            let b = [];
            b.push(...row(0, 3, 17, 'grass'));
            b.push(g(4, 17, 'lava'), g(5, 17, 'lava'));
            b.push(g(6, 15, 'grass'), g(7, 15, 'grass'));
            b.push(g(8, 17, 'lava'), g(9, 17, 'lava'));
            b.push(g(10, 17, 'grass'), g(11, 17, 'grass'));
            b.push(g(12, 17, 'lava'), g(13, 17, 'lava'));
            b.push(g(14, 15, 'grass'), g(15, 15, 'grass'));
            b.push(g(16, 17, 'trigger'), g(17, 17, 'spike'));
            b.push(...row(19, 24, 17, 'grass'));
            b.push(portal(22, 14));
            return b;
        },
        // L6 — Grass Bridge + Troll Spikes + Visible Spikes + Lava + Fake Grass (Gird + f)
        () => {
            let b = [];
            // Row 8: Portal at col 4, grass bridge with troll spike and visible spikes
            b.push(portal(4, 6)); // Portal spans rows 6-8
            b.push(g(5, 8, 'fake_grass'), g(6, 8, 'grass'), g(7, 8, 'grass')); // f=fake grass at start!
            b.push(g(8, 8, 'spike'), g(9, 8, 'trigger')); // Troll spike
            b.push(g(10, 8, 'spike_visible'), g(11, 8, 'spike_visible'));
            b.push(g(12, 8, 'grass'), g(13, 8, 'grass'), g(14, 8, 'fake_grass'), g(15, 8, 'grass'), g(16, 8, 'grass')); // f in bridge
            // Row 10: Small platform
            b.push(g(19, 10, 'grass'), g(20, 10, 'grass'));
            // Row 12: Small platform
            b.push(g(23, 12, 'grass'), g(24, 12, 'fake_grass')); // f at edge
            // Row 14: Main ground with hazards
            b.push(...row(0, 4, 14, 'grass'));
            b.push(g(5, 14, 'spike_visible'), g(6, 14, 'spike_visible'), g(7, 14, 'spike_visible'), g(8, 14, 'spike_visible'));
            b.push(g(9, 14, 'grass'), g(10, 14, 'trigger'), g(11, 14, 'spike')); // Troll spike
            b.push(g(15, 14, 'fake_grass'), ...row(16, 20, 14, 'grass')); // f hidden in ground
            b.push(g(21, 14, 'lava'), g(22, 14, 'lava'), g(23, 14, 'lava'));
            b.push(g(24, 14, 'grass'));
            // Row 15: Dirt and visible spikes below
            b.push(g(0, 15, 'dirt'), g(3, 15, 'dirt'));
            b.push(...row(12, 22, 15, 'spike_visible'));
