<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>1v1 Football</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:#0a0e14;display:flex;flex-direction:column;justify-content:center;align-items:center;min-height:100vh;overflow:hidden;font-family:sans-serif}
  canvas{display:block;border-radius:12px;box-shadow:0 0 60px rgba(255,107,53,0.06),0 0 60px rgba(0,212,170,0.06)}
  #info{color:#555;font-size:13px;margin-top:14px;text-align:center}
  #info kbd{background:#151a22;border:1px solid #2a3040;border-radius:4px;padding:2px 7px;color:#aaa;font-size:12px}
</style>
</head>
<body>
<canvas id="c"></canvas>
<div id="info"><kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd> move &middot; <kbd>Space</kbd> dash &middot; First to 5 wins</div>
<script>
const cv=document.getElementById('c');
const cx=cv.getContext('2d');
const W=960,H=540;
cv.width=W;cv.height=H;

function resize(){
  const r=W/H;let w=innerWidth*.96,h=innerHeight*.84;
  if(w/h>r)w=h*r;else h=w/r;
  cv.style.width=w+'px';cv.style.height=h+'px';
}
addEventListener('resize',resize);resize();

/* ── constants ── */
const FX=60,FY=50,FW=840,FH=440;
const FCX=FX+FW/2,FCY=FY+FH/2;
const GD=30,GH=150;
const GT=FCY-GH/2,GB=FCY+GH/2;
const PR=22,BR=11;
const PS=5.2;
const BFRIC=0.986,WBOUNCE=0.65;
const KBASE=5.5,KVMUL=1.6,MAXBS=22;
const DSPD=14,DUR=7,DCD=55;
const WIN=5;

/* ── DIFFICULTY CONFIG ── */
const DIFF={
  easy:{speed:3.9,reactFar:.09,reactClose:.16,mistakeChance:.005,goalAimChance:0,goalAimNoise:.45,depthLimit:.25,bigMissChance:.08,bigMissAngle:1.2,bigMissPower:.6},
  medium:{speed:4.3,reactFar:.12,reactClose:.19,mistakeChance:.002,goalAimChance:.5,goalAimNoise:.25,depthLimit:.15,bigMissChance:.03,bigMissAngle:.8,bigMissPower:.7},
  hard:{speed:4.8,reactFar:.16,reactClose:.22,mistakeChance:.0005,goalAimChance:.8,goalAimNoise:.12,depthLimit:.05,bigMissChance:.01,bigMissAngle:.5,bigMissPower:.8}
};

/* ── MAP CONFIG ── */
const MAPS={
  grass:{stripe1:'#2b8c4a',stripe2:'#278743',line:'rgba(255,255,255,0.5)',goalPost:'#bbb',bg:'rgba(25,50,35,0.3)'},
  dirt:{stripe1:'#8B6914',stripe2:'#7A5B10',line:'rgba(255,255,255,0.3)',goalPost:'#9f9f6f',bg:'rgba(50,35,10,0.3)'},
  neon:{stripe1:'#0a0a1a',stripe2:'#0f0f2a',line:'#0ff',goalPost:'#f0f',bg:'rgba(20,0,50,0.4)'}
};

/* ── GAME OPTIONS ── */
let optDiff='easy',cfg=DIFF.easy;
let optMap='grass',mapCfg=MAPS.grass;
let optSkin='circle';

/* ── audio ── */
let ac=null;
function ea(){if(!ac)try{ac=new(AudioContext||webkitAudioContext)()}catch(e){}}
function snd(freq,dur,type,vol){
  ea();if(!ac)return;
  try{
    const o=ac.createOscillator(),g=ac.createGain();
    o.connect(g);g.connect(ac.destination);
    o.frequency.value=freq;o.type=type||'triangle';
    g.gain.setValueAtTime(vol||.1,ac.currentTime);
    g.gain.exponentialRampToValueAtTime(.001,ac.currentTime+dur);
    o.start();o.stop(ac.currentTime+dur);
  }catch(e){}
}

/* ── state ── */
let st='menu',sc=[0,0],cdT=0,glT=0,lastSc=-1;
let gTime=0,shake=0,gFlash=0;
let pl,bt,bl;
let trail=[],pts=[],cft=[];
let keys={};
let dTimer=0,dCD=0,dDX=0,dDY=0;
let botMistakeTimer=0,botMistakeDX=0,botMistakeDY=0;

function resetPos(){
  pl={x:FX+FW*.25,y:FCY,vx:0,vy:0};
  bt={x:FX+FW*.75,y:FCY,vx:0,vy:0};
  bl={x:FCX,y:FCY,vx:0,vy:0};
  trail=[];dTimer=0;dCD=0;botMistakeTimer=0;
}
resetPos();

/* ── input ── */
addEventListener('keydown',e=>{
  keys[e.key.toLowerCase()]=true;
  if(e.key===' '||e.key.startsWith('Arrow'))e.preventDefault();
  if(e.key===' '&&st==='gameover')st='menu';
});
addEventListener('keyup',e=>{keys[e.key.toLowerCase()]=false;});

/* ── mouse ── */
let mx=0,my=0;
cv.addEventListener('mousemove',e=>{
  let r=cv.getBoundingClientRect();
  mx=(e.clientX-r.left)*(W/r.width);
  my=(e.clientY-r.top)*(H/r.height);
});

/* ── menu button helper ── */
function btn(x,y,w,h,label,color,active){
  let hover=mx>x&&mx<x+w&&my>y&&my<y+h;
  let bg=active?color+'33':(hover?color+'22':'#11111166');
  let border=active?color:(hover?color+'aa':color+'44');
  cx.fillStyle=bg;cx.fillRect(x,y,w,h);
  cx.strokeStyle=border;cx.lineWidth=active?3:1;cx.strokeRect(x,y,w,h);
  cx.fillStyle=active?color:(hover?color+'cc':color+'88');
  cx.font='bold 16px monospace';cx.textAlign='center';cx.textBaseline='middle';
  cx.fillText(label,x+w/2,y+h/2);
  return hover;
}
function btnClick(bx,by,bw,bh){return mx>bx&&mx<bx+bw&&my>by&&my<by+bh;}

cv.addEventListener('click',()=>{
  if(st==='menu'){
    const bw=140,bh=42,gap=15;
    const totalW=3*bw+2*gap;
    const sx=FCX-totalW/2;

    // Diff row
    let dy=FCY-50;
    if(btnClick(sx,dy,bw,bh)){optDiff='easy';cfg=DIFF.easy;}
    if(btnClick(sx+bw+gap,dy,bw,bh)){optDiff='medium';cfg=DIFF.medium;}
    if(btnClick(sx+2*(bw+gap),dy,bw,bh)){optDiff='hard';cfg=DIFF.hard;}

    // Map row
    dy=FCY+10;
    if(btnClick(sx,dy,bw,bh))optMap='grass';
    if(btnClick(sx+bw+gap,dy,bw,bh))optMap='dirt';
    if(btnClick(sx+2*(bw+gap),dy,bw,bh))optMap='neon';

    // Skin row
    dy=FCY+70;
    if(btnClick(sx,dy,bw,bh))optSkin='circle';
    if(btnClick(sx+bw+gap,dy,bw,bh))optSkin='square';
    if(btnClick(sx+2*(bw+gap),dy,bw,bh))optSkin='arrow';

    // Play button
    let pw=200,ph=50,px=FCX-pw/2,py=FCY+140;
    if(btnClick(px,py,pw,ph))startGame();
  }
  if(st==='gameover')st='menu';
});

function startGame(){
  ea();sc=[0,0];gTime=0;resetPos();
  mapCfg=MAPS[optMap];
  st='countdown';cdT=2.5;snd(780,.35,'sine',.1);
}

/* ── particles ── */
function spawnKick(x,y,n,col){
  for(let i=0;i<n;i++){
    let a=Math.random()*6.28,s=1+Math.random()*4;
    pts.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,l:1,d:.03+Math.random()*.02,sz:2+Math.random()*3,c:col});
  }
}
function spawnGoal(x,y){
  const cols=['#ffd700','#ff6b35','#00d4aa','#fff','#ff4466'];
  for(let i=0;i<55;i++){
    let a=Math.random()*6.28,s=2+Math.random()*7;
    cft.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s-2,l:1,d:.007+Math.random()*.008,
      sz:3+Math.random()*5,c:cols[Math.floor(Math.random()*5)],r:Math.random()*6.28,rs:(Math.random()-.5)*.2});
  }
}
function updParts(){
  for(let i=pts.length-1;i>=0;i--){let p=pts[i];p.x+=p.vx;p.y+=p.vy;p.vx*=.96;p.vy*=.96;p.l-=p.d;if(p.l<=0)pts.splice(i,1);}
  for(let i=cft.length-1;i>=0;i--){let c=cft[i];c.x+=c.vx;c.y+=c.vy;c.vy+=.08;c.vx*=.99;c.r+=c.rs;c.l-=c.d;if(c.l<=0)cft.splice(i,1);}
}

/* ── physics ── */
function constrain(p){
  p.x=Math.max(FX+PR,Math.min(FX+FW-PR,p.x));
  p.y=Math.max(FY+PR,Math.min(FY+FH-PR,p.y));
}

function pBall(p,isBot){
  let dx=bl.x-p.x,dy=bl.y-p.y;
  let d=Math.sqrt(dx*dx+dy*dy);
  let mn=PR+BR;
  if(d<mn&&d>.01){
    let nx=dx/d,ny=dy/d;
    bl.x=p.x+nx*mn;bl.y=p.y+ny*mn;
    let ps=Math.sqrt(p.vx*p.vx+p.vy*p.vy);
    let f=KBASE+ps*KVMUL;
    if(!isBot&&dTimer>0)f*=1.5;

    if(isBot){
      let kickAngle;
      if(Math.random()<cfg.goalAimChance){
        let goalTargetY=GT+20+Math.random()*(GH-40);
        let ga=Math.atan2(goalTargetY-bl.y,FX-bl.x);
        ga+=(Math.random()-.5)*cfg.goalAimNoise;
        kickAngle=ga;
      }else{
        if(ps>1)kickAngle=Math.atan2(p.vy,p.vx);
        else kickAngle=Math.atan2(ny,nx);
        kickAngle+=(Math.random()-.5)*.45;
      }
      if(Math.random()<cfg.bigMissChance){
        kickAngle+=(Math.random()-.5)*cfg.bigMissAngle;
        f*=cfg.bigMissPower;
      }
      bl.vx=Math.cos(kickAngle)*f;bl.vy=Math.sin(kickAngle)*f;
    }else{
      bl.vx=nx*f+p.vx*.4;bl.vy=ny*f+p.vy*.4;
    }
    let bs=Math.sqrt(bl.vx*bl.vx+bl.vy*bl.vy);
    if(bs>MAXBS){bl.vx=bl.vx/bs*MAXBS;bl.vy=bl.vy/bs*MAXBS;}
    shake=Math.min(f*.7,9);
    spawnKick(bl.x-nx*BR,bl.y-ny*BR,9,isBot?'#00d4aa':'#ff6b35');
    snd(160+Math.random()*80,.09,'triangle',.12);
  }
}

function ppCol(){
  let dx=bt.x-pl.x,dy=bt.y-pl.y;
  let d=Math.sqrt(dx*dx+dy*dy);
  let mn=PR*2;
  if(d<mn&&d>.01){
    let nx=dx/d,ny=dy/d,ov=mn-d;
    pl.x-=nx*ov*.5;pl.y-=ny*ov*.5;
    bt.x+=nx*ov*.5;bt.y+=ny*ov*.5;
  }
}

function updBall(){
  bl.x+=bl.vx;bl.y+=bl.vy;
  bl.vx*=BFRIC;bl.vy*=BFRIC;
  if(Math.abs(bl.vx)<.005)bl.vx=0;
  if(Math.abs(bl.vy)<.005)bl.vy=0;
  if(bl.y-BR<FY){bl.y=FY+BR;bl.vy=Math.abs(bl.vy)*WBOUNCE;}
  if(bl.y+BR>FY+FH){bl.y=FY+FH-BR;bl.vy=-Math.abs(bl.vy)*WBOUNCE;}
  if(bl.x-BR<FX){
    if(bl.y>GT&&bl.y<GB){
      if(bl.x<FX-GD+BR){bl.x=FX-GD+BR;bl.vx=Math.abs(bl.vx)*.3;}
      if(bl.y-BR<GT){bl.y=GT+BR;bl.vy=Math.abs(bl.vy)*WBOUNCE;}
      if(bl.y+BR>GB){bl.y=GB-BR;bl.vy=-Math.abs(bl.vy)*WBOUNCE;}
    }else{bl.x=FX+BR;bl.vx=Math.abs(bl.vx)*WBOUNCE;}
  }
  if(bl.x+BR>FX+FW){
    if(bl.y>GT&&bl.y<GB){
      if(bl.x>FX+FW+GD-BR){bl.x=FX+FW+GD-BR;bl.vx=-Math.abs(bl.vx)*.3;}
      if(bl.y-BR<GT){bl.y=GT+BR;bl.vy=Math.abs(bl.vy)*WBOUNCE;}
      if(bl.y+BR>GB){bl.y=GB-BR;bl.vy=-Math.abs(bl.vy)*WBOUNCE;}
    }else{bl.x=FX+FW-BR;bl.vx=-Math.abs(bl.vx)*WBOUNCE;}
  }
  let sp=Math.sqrt(bl.vx*bl.vx+bl.vy*bl.vy);
  if(sp>1.5)trail.push({x:bl.x,y:bl.y,a:1,s:BR*.65});
  for(let i=trail.length-1;i>=0;i--){trail[i].a-=.06;trail[i].s*=.94;if(trail[i].a<=0)trail.splice(i,1);}
}

function checkGoal(){
  if(bl.x<FX-BR*.5&&bl.y>GT&&bl.y<GB){goal(1);return;}
  if(bl.x>FX+FW+BR*.5&&bl.y>GT&&bl.y<GB){goal(0);return;}
}

function goal(who){
  sc[who]++;lastSc=who;st='goal';glT=2.2;gFlash=1;
  spawnGoal(bl.x,bl.y);snd(350,.5,'sawtooth',.15);
}

/* ── player ── */
function updPlayer(){
  let dx=0,dy=0;
  if(keys['w']||keys['arrowup'])dy=-1;
  if(keys['s']||keys['arrowdown'])dy=1;
  if(keys['a']||keys['arrowleft'])dx=-1;
  if(keys['d']||keys['arrowright'])dx=1;
  let ln=Math.sqrt(dx*dx+dy*dy);
  if(ln>0){dx/=ln;dy/=ln;}
  if(dCD>0)dCD--;
  if(keys[' ']&&dCD<=0&&dTimer<=0&&(dx!==0||dy!==0)){
    dTimer=DUR;dCD=DCD;dDX=dx;dDY=dy;
  }
  if(dTimer>0){pl.vx=dDX*DSPD;pl.vy=dDY*DSPD;dTimer--;}
  else{pl.vx=dx*PS;pl.vy=dy*PS;}
  pl.x+=pl.vx;pl.y+=pl.vy;constrain(pl);
}

/* ── bot AI ── */
function updBot(){
  let bsp=Math.sqrt(bl.vx*bl.vx+bl.vy*bl.vy);
  let distBall=Math.sqrt((bl.x-bt.x)**2+(bl.y-bt.y)**2);
  let spd=cfg.speed;

  if(botMistakeTimer>0){botMistakeTimer--;}
  else if(Math.random()<cfg.mistakeChance){
    botMistakeTimer=30+Math.random()*40;
    botMistakeDX=(Math.random()-.5)*120;
    botMistakeDY=(Math.random()-.5)*120;
  }

  let tx,ty;
  if(bl.vx>3.5&&bl.x>FCX-60&&bsp>4){
    let tFrame=Math.max(1,(bt.x-bl.x)/Math.max(bl.vx,.5));
    let iy=bl.y+bl.vy*tFrame;
    iy=Math.max(FY+PR,Math.min(FY+FH-PR,iy));
    tx=FX+FW-70;ty=iy;spd=cfg.speed*1.15;
  }else if(bl.x>FCX-80){
    if(bt.x>bl.x+5){tx=bl.x;ty=bl.y;spd=cfg.speed*1.05;}
    else{tx=bl.x+45;ty=bl.y;if(bl.y<FCY-50)ty=bl.y+40;else if(bl.y>FCY+50)ty=bl.y-40;}
  }else{
    if(bt.x>bl.x+10){tx=bl.x;ty=bl.y;spd=cfg.speed*1.05;}
    else{tx=bl.x+55;ty=bl.y;spd=cfg.speed*1.1;}
  }

  let minXF=FX+FW*cfg.depthLimit;
  if(distBall>100)minXF=FX+FW*(cfg.depthLimit+0.1);
  tx=Math.max(minXF,tx);

  if(botMistakeTimer>0){tx+=botMistakeDX;ty+=botMistakeDY;}
  tx=Math.max(FX+PR,Math.min(FX+FW-PR,tx));
  ty=Math.max(FY+PR,Math.min(FY+FH-PR,ty));

  let tdx=tx-bt.x,tdy=ty-bt.y;
  let td=Math.sqrt(tdx*tdx+tdy*tdy);
  if(td>5){
    let dvx=(tdx/td)*spd,dvy=(tdy/td)*spd;
    let react=distBall<60?cfg.reactClose:cfg.reactFar;
    bt.vx+=(dvx-bt.vx)*react;bt.vy+=(dvy-bt.vy)*react;
  }else{bt.vx*=.85;bt.vy*=.85;}
  bt.x+=bt.vx;bt.y+=bt.vy;constrain(bt);
}

/* ── main update ── */
function update(){
  if(st==='playing'){
    updPlayer();updBot();ppCol();
    pBall(pl,false);pBall(bt,true);
    updBall();checkGoal();gTime+=1/60;
  }else if(st==='countdown'){
    cdT-=1/60;if(cdT<=0){st='playing';snd(780,.3,'sine',.1);}
  }else if(st==='goal'){
    bl.vx*=.92;bl.vy*=.92;updBall();
    glT-=1/60;gFlash*=.95;
    if(glT<=0){
      if(sc[0]>=WIN||sc[1]>=WIN)st='gameover';
      else{resetPos();st='countdown';cdT=1.8;snd(780,.3,'sine',.1);}
    }
  }
  updParts();shake*=.87;
}

/* ── rendering ── */
function rBG(){
  cx.fillStyle='#0a0e14';cx.fillRect(0,0,W,H);
  let g=cx.createRadialGradient(FCX,FCY,50,FCX,FCY,500);
  g.addColorStop(0,mapCfg.bg);g.addColorStop(1,'rgba(0,0,0,0)');
  cx.fillStyle=g;cx.fillRect(0,0,W,H);
}

function rField(){
  let mc=mapCfg;
  let sh=FH/12;
  for(let i=0;i<12;i++){cx.fillStyle=i%2?mc.stripe2:mc.stripe1;cx.fillRect(FX,FY+i*sh,FW,sh+1);}
  cx.strokeStyle=mc.line;cx.lineWidth=2;
  if(optMap==='neon'){cx.shadowBlur=8;cx.shadowColor=mc.line;}
  cx.strokeRect(FX,FY,FW,FH);
  cx.beginPath();cx.moveTo(FCX,FY);cx.lineTo(FCX,FY+FH);cx.stroke();
  cx.beginPath();cx.arc(FCX,FCY,60,0,6.28);cx.stroke();
  cx.fillStyle=mc.line;cx.beginPath();cx.arc(FCX,FCY,4,0,6.28);cx.fill();
  let pw=130,ph=280,py=FCY-ph/2;
  cx.strokeRect(FX,py,pw,ph);cx.strokeRect(FX+FW-pw,py,pw,ph);
  let gw=50,gh=140,gy=FCY-gh/2;
  cx.strokeRect(FX,gy,gw,gh);cx.strokeRect(FX+FW-gw,gy,gw,gh);
  cx.beginPath();cx.arc(FX+100,FCY,3,0,6.28);cx.fill();
  cx.beginPath();cx.arc(FX+FW-100,FCY,3,0,6.28);cx.fill();
  let cr=14;
  cx.beginPath();cx.arc(FX,FY,cr,0,Math.PI/2);cx.stroke();
  cx.beginPath();cx.arc(FX+FW,FY,cr,Math.PI/2,Math.PI);cx.stroke();
  cx.beginPath();cx.arc(FX,FY+FH,cr,-Math.PI/2,0);cx.stroke();
  cx.beginPath();cx.arc(FX+FW,FY+FH,cr,Math.PI,Math.PI*1.5);cx.stroke();
  cx.shadowBlur=0; // reset neon glow
}

function rGoals(){
  let mc=mapCfg;
  if(optMap==='neon'){cx.shadowBlur=10;cx.shadowColor=mc.goalPost;}
  cx.fillStyle='rgba(0,0,0,0.3)';cx.fillRect(FX-GD,GT,GD,GH);
  cx.strokeStyle='rgba(255,255,255,0.1)';cx.lineWidth=1;cx.shadowBlur=0;
  for(let y=GT;y<=GB;y+=12){cx.beginPath();cx.moveTo(FX-GD,y);cx.lineTo(FX,y);cx.stroke();}
  for(let x=FX-GD;x<=FX;x+=10){cx.beginPath();cx.moveTo(x,GT);cx.lineTo(x,GB);cx.stroke();}
  cx.strokeStyle=mc.goalPost;cx.lineWidth=4;
  if(optMap==='neon'){cx.shadowBlur=12;cx.shadowColor=mc.goalPost;}
  cx.beginPath();cx.moveTo(FX,GT);cx.lineTo(FX-GD,GT);cx.lineTo(FX-GD,GB);cx.lineTo(FX,GB);cx.stroke();

  cx.fillStyle='rgba(0,0,0,0.3)';cx.fillRect(FX+FW,GT,GD,GH);
  cx.strokeStyle='rgba(255,255,255,0.1)';cx.lineWidth=1;cx.shadowBlur=0;
  for(let y=GT;y<=GB;y+=12){cx.beginPath();cx.moveTo(FX+FW,y);cx.lineTo(FX+FW+GD,y);cx.stroke();}
  for(let x=FX+FW;x<=FX+FW+GD;x+=10){cx.beginPath();cx.moveTo(x,GT);cx.lineTo(x,GB);cx.stroke();}
  cx.strokeStyle=mc.goalPost;cx.lineWidth=4;
  if(optMap==='neon'){cx.shadowBlur=12;cx.shadowColor=mc.goalPost;}
  cx.beginPath();cx.moveTo(FX+FW,GT);cx.lineTo(FX+FW+GD,GT);cx.lineTo(FX+FW+GD,GB);cx.lineTo(FX+FW,GB);cx.stroke();
  cx.shadowBlur=0;
}

function rTrail(){
  for(let t of trail){cx.globalAlpha=t.a*.3;cx.fillStyle=optMap==='neon'?'#0ff':'#fff';cx.beginPath();cx.arc(t.x,t.y,t.s,0,6.28);cx.fill();}
  cx.globalAlpha=1;
}

function rBall(){
  cx.fillStyle='rgba(0,0,0,0.18)';
  cx.beginPath();cx.ellipse(bl.x+3,bl.y+4,BR,BR*.55,0,0,6.28);cx.fill();
  let g=cx.createRadialGradient(bl.x-3,bl.y-3,1,bl.x,bl.y,BR);
  if(optMap==='neon'){g.addColorStop(0,'#fff');g.addColorStop(1,'#0ff');}
  else{g.addColorStop(0,'#ffffff');g.addColorStop(1,'#bbbbbb');}
  cx.fillStyle=g;cx.beginPath();cx.arc(bl.x,bl.y,BR,0,6.28);cx.fill();
  if(optMap==='neon'){cx.shadowBlur=10;cx.shadowColor='#0ff';cx.beginPath();cx.arc(bl.x,bl.y,BR,0,6.28);cx.stroke();cx.shadowBlur=0;}
  cx.strokeStyle='rgba(0,0,0,0.12)';cx.lineWidth=1;
  let sp=Math.sqrt(bl.vx*bl.vx+bl.vy*bl.vy);
  let rot=gTime*sp*.08;
  for(let i=0;i<5;i++){
    let a=rot+i*6.28/5;
    cx.beginPath();cx.arc(bl.x+Math.cos(a)*BR*.5,bl.y+Math.sin(a)*BR*.5,BR*.22,0,6.28);cx.stroke();
  }
}

/* ── player skin rendering ── */
function rPlayer(p,col,lbl){
  let sp=Math.sqrt(p.vx*p.vx+p.vy*p.vy);
  let a=Math.atan2(p.vy,p.vx);

  // Glow
  let g=cx.createRadialGradient(p.x,p.y,PR*.4,p.x,p.y,PR*2.2);
  g.addColorStop(0,col+'44');g.addColorStop(1,col+'00');
  cx.fillStyle=g;cx.beginPath();cx.arc(p.x,p.y,PR*2.2,0,6.28);cx.fill();

  if(optMap==='neon'){cx.shadowBlur=8;cx.shadowColor=col;}

  // Shadow
  cx.fillStyle='rgba(0,0,0,0.18)';
  cx.beginPath();cx.ellipse(p.x+2,p.y+4,PR,PR*.5,0,0,6.28);cx.fill();

  // Body
  let bg=cx.createRadialGradient(p.x-4,p.y-4,2,p.x,p.y,PR);
  bg.addColorStop(0,col);bg.addColorStop(1,'rgba(0,0,0,0.35)');
  cx.fillStyle=bg;

  if(optSkin==='circle'){
    cx.beginPath();cx.arc(p.x,p.y,PR,0,6.28);cx.fill();
    cx.strokeStyle='rgba(255,255,255,0.25)';cx.lineWidth=2;cx.beginPath();cx.arc(p.x,p.y,PR,0,6.28);cx.stroke();
  }else if(optSkin==='square'){
    let s=PR*1.6;
    cx.save();cx.translate(p.x,p.y);cx.rotate(a);
    cx.beginPath();cx.roundRect(-s/2,-s/2,s,s,4);cx.fill();
    cx.strokeStyle='rgba(255,255,255,0.25)';cx.lineWidth=2;cx.beginPath();cx.roundRect(-s/2,-s/2,s,s,4);cx.stroke();
    cx.restore();
  }else if(optSkin==='arrow'){
    cx.save();cx.translate(p.x,p.y);cx.rotate(a);
    cx.beginPath();cx.moveTo(PR*1.3,0);cx.lineTo(-PR*.8,-PR);cx.lineTo(-PR*.4,0);cx.lineTo(-PR*.8,PR);cx.closePath();cx.fill();
    cx.strokeStyle='rgba(255,255,255,0.25)';cx.lineWidth=2;cx.stroke();
    cx.restore();
  }

  cx.shadowBlur=0;

  // Direction arrow (for circle skin only, others have built-in direction)
  if(optSkin==='circle'&&sp>1){
    cx.fillStyle='rgba(255,255,255,0.6)';cx.beginPath();
    cx.moveTo(p.x+Math.cos(a)*PR*.5,p.y+Math.sin(a)*PR*.5);
    cx.lineTo(p.x+Math.cos(a)*PR*1.3,p.y+Math.sin(a)*PR*1.3);
    cx.lineTo(p.x+Math.cos(a+2.6)*PR*.6,p.y+Math.sin(a+2.6)*PR*.6);
    cx.closePath();cx.fill();
  }

  cx.fillStyle='rgba(255,255,255,0.8)';cx.font='bold 11px sans-serif';cx.textAlign='center';
  cx.fillText(lbl,p.x,p.y-PR-7);
}

function rParts(){
  for(let p of pts){cx.globalAlpha=p.l;cx.fillStyle=p.c;cx.beginPath();cx.arc(p.x,p.y,p.sz,0,6.28);cx.fill();}
  for(let c of cft){cx.globalAlpha=c.l;cx.fillStyle=c.c;cx.save();cx.translate(c.x,c.y);cx.rotate(c.r);cx.fillRect(-c.sz/2,-c.sz/4,c.sz,c.sz/2);cx.restore();}
  cx.globalAlpha=1;
}

function rHUD(){
  cx.font='bold 48px monospace';cx.textAlign='center';
  cx.fillStyle='#ff6b35';cx.fillText(sc[0],FCX-55,FY-8);
  cx.fillStyle='#444';cx.font='bold 28px monospace';cx.fillText(':',FCX,FY-8);
  cx.fillStyle='#00d4aa';cx.font='bold 48px monospace';cx.fillText(sc[1],FCX+55,FY-8);
  cx.font='bold 12px sans-serif';
  cx.fillStyle='#ff6b35';cx.fillText('YOU',FCX-55,FY-26);
  cx.fillStyle='#00d4aa';cx.fillText('BOT',FCX+55,FY-26);
  let m=Math.floor(gTime/60),s=Math.floor(gTime%60);
  cx.fillStyle='#666';cx.font='14px monospace';
  cx.fillText((m<10?'0':'')+m+':'+(s<10?'0':'')+s,FCX,FY-26);
  let bw=50,bh=4,bx=pl.x-bw/2,by=pl.y+PR+10;
  cx.fillStyle='rgba(0,0,0,0.4)';cx.fillRect(bx,by,bw,bh);
  let pct=dCD>0?1-dCD/DCD:1;
  cx.fillStyle=pct>=1?'#ff6b35':'#552200';cx.fillRect(bx,by,bw*pct,bh);
  if(pct>=1){cx.strokeStyle='rgba(255,107,53,0.5)';cx.lineWidth=1;cx.strokeRect(bx-1,by-1,bw+2,bh+2);}
  let dCol=optDiff==='easy'?'#55ff55':optDiff==='medium'?'#ffaa00':'#ff4444';
  cx.fillStyle=dCol;cx.font='bold 10px sans-serif';cx.textAlign='left';
  cx.fillText(optDiff.toUpperCase()+' | '+optMap.toUpperCase()+' | '+optSkin.toUpperCase(),FX+4,FY+FH+16);
}

function rCountdown(){
  let n=Math.ceil(cdT);if(n>3)n=3;if(n<1)n=1;
  let f=cdT-Math.floor(cdT);
  let sc2=1+f*.5,al=Math.min(1,f*2.5);
  cx.save();cx.translate(FCX,FCY);cx.scale(sc2,sc2);cx.globalAlpha=al;
  cx.font='bold 110px monospace';cx.textAlign='center';cx.textBaseline='middle';
  cx.fillStyle=n<=1?'#ffd700':'#ffffff';cx.fillText(n<=0?'GO':String(n),0,0);
  cx.globalAlpha=1;cx.restore();
}

function rGoalCeleb(){
  if(gFlash>.01){
    let c=lastSc===0?'255,107,53':'0,212,170';
    cx.fillStyle='rgba('+c+','+gFlash*.25+')';cx.fillRect(0,0,W,H);
  }
  if(glT>.4){
    let s=1+(2.2-glT)*.3;
    cx.save();cx.translate(FCX,FCY);cx.scale(s,s);
    cx.font='bold 72px monospace';cx.textAlign='center';cx.textBaseline='middle';
    cx.fillStyle=lastSc===0?'#ff6b35':'#00d4aa';
    cx.fillText('GOAL!',0,0);cx.strokeStyle='rgba(0,0,0,0.4)';cx.lineWidth=3;cx.strokeText('GOAL!',0,0);
    cx.restore();
  }
}

/* ── menu ── */
function rMenu(){
  cx.fillStyle='rgba(10,14,20,0.95)';cx.fillRect(0,0,W,H);
  cx.font='bold 52px monospace';cx.textAlign='center';cx.textBaseline='middle';
  cx.fillStyle='#fff';cx.fillText('1V1 FOOTBALL',FCX,FCY-130);

  const bw=140,bh=42,gap=15;
  const totalW=3*bw+2*gap;
  const sx=FCX-totalW/2;

  // Difficulty
  cx.font='bold 13px sans-serif';cx.fillStyle='#888';cx.fillText('DIFFICULTY',FCX,FCY-72);
  let dy=FCY-50;
  btn(sx,dy,bw,bh,'EASY','#55ff55',optDiff==='easy');
  btn(sx+bw+gap,dy,bw,bh,'MEDIUM','#ffaa00',optDiff==='medium');
  btn(sx+2*(bw+gap),dy,bw,bh,'HARD','#ff4444',optDiff==='hard');

  // Maps
  cx.font='bold 13px sans-serif';cx.fillStyle='#888';cx.fillText('MAP',FCX,FCY-12);
  dy=FCY+10;
  btn(sx,dy,bw,bh,'GRASS','#44aa44',optMap==='grass');
  btn(sx+bw+gap,dy,bw,bh,'DIRT','#aa8833',optMap==='dirt');
  btn(sx+2*(bw+gap),dy,bw,bh,'NEON','#00ffff',optMap==='neon');

  // Skins
  cx.font='bold 13px sans-serif';cx.fillStyle='#888';cx.fillText('STYLE',FCX,FCY+48);
  dy=FCY+70;
  btn(sx,dy,bw,bh,'CIRCLE','#ff6b35',optSkin==='circle');
  btn(sx+bw+gap,dy,bw,bh,'SQUARE','#ff6b35',optSkin==='square');
  btn(sx+2*(bw+gap),dy,bw,bh,'ARROW','#ff6b35',optSkin==='arrow');

  // Play
  let pw=200,ph=50,px=FCX-pw/2,py=FCY+140;
  let hov=mx>px&&mx<px+pw&&my>py&&my<py+ph;
  cx.fillStyle=hov?'#ffd700':'#ffc200';cx.fillRect(px,py,pw,ph);
  cx.fillStyle='#0a0e14';cx.font='bold 22px monospace';
  cx.fillText('PLAY',FCX,py+ph/2);

  cx.font='14px sans-serif';cx.fillStyle='#444';cx.textAlign='center';
  cx.fillText('WASD to move  |  SPACE to dash  |  First to 5 goals',FCX,FCY+210);
}

function rGameOver(){
  cx.fillStyle='rgba(10,14,20,0.9)';cx.fillRect(0,0,W,H);
  let w=sc[0]>=WIN?0:1;
  let c=w===0?'#ff6b35':'#00d4aa';
  cx.font='bold 52px monospace';cx.textAlign='center';cx.textBaseline='middle';
  cx.fillStyle=c;cx.fillText(w===0?'YOU WIN!':'BOT WINS!',FCX,FCY-50);
  cx.font='bold 30px monospace';cx.fillStyle='#fff';cx.fillText(sc[0]+' : '+sc[1],FCX,FCY+10);
  let pulse=.5+Math.sin(Date.now()*.004)*.5;
  cx.globalAlpha=.5+pulse*.5;cx.font='bold 18px sans-serif';cx.fillStyle='#ffd700';
  cx.fillText('Click or press SPACE to continue',FCX,FCY+65);cx.globalAlpha=1;
}

/* ── main render ── */
function render(){
  cx.save();
  if(shake>.3)cx.translate((Math.random()-.5)*shake,(Math.random()-.5)*shake);
  rBG();rField();rGoals();rTrail();rBall();
  rPlayer(pl,'#ff6b35','YOU');rPlayer(bt,'#00d4aa','BOT');
  rParts();rHUD();
  if(st==='countdown')rCountdown();
  if(st==='goal')rGoalCeleb();
  if(st==='menu')rMenu();
  if(st==='gameover')rGameOver();
  cx.restore();
}

function loop(){update();render();requestAnimationFrame(loop);}
loop();
</script>
